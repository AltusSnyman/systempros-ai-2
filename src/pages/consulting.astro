---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import ProductVideoPlayer from '../components/ProductVideoPlayer';
---

<Layout
    title="Digital Architecture Consulting | SystemPros.ai"
    description="Forensic audit of your operations followed by a strategic AI roadmap. 30 years of enterprise IT architecture experience applied to your business. Not just tools — a system."
>
    <ServiceSchema name="AI Consultation" description="Forensic operational audit and strategic AI roadmap service with 30 years of enterprise IT architecture experience." serviceType="ConsultingService" />
    <Breadcrumbs currentTitle="Consultation" />

    <main class="overflow-x-hidden">

        <!-- ════════════════════════════════════════════════════════
             HERO
        ════════════════════════════════════════════════════════ -->
        <section class="relative pt-32 pb-24 overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(34,211,238,0.15)_0%,transparent_60%)]" />
            <div class="container mx-auto px-4 relative z-10">
                <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

                    <!-- Copy -->
                    <div>
                        <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest uppercase text-cyan-400 border border-cyan-500/25 bg-cyan-500/5 rounded-full px-4 py-2 mb-8">
                            <span class="w-1.5 h-1.5 rounded-full bg-cyan-400 inline-block"></span>
                            Strategy & Audit
                        </div>

                        <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tighter mb-6">
                            Software is Cheap.<br />
                            <span class="text-gradient">Strategy is Priceless.</span>
                        </h1>

                        <p class="text-lg text-secondary leading-relaxed mb-10 max-w-xl">
                            Any agency can give you a login. We build the infrastructure, train the neural networks, and integrate AI securely into your existing systems. <strong class="text-white">30 years of Enterprise IT experience</strong> applied to modern automation.
                        </p>

                        <div class="flex flex-wrap gap-4">
                            <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-base px-8 py-4">
                                Book Your Forensic Audit
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </a>
                            <a href="#methodology" class="inline-flex items-center gap-2 text-base px-8 py-4 rounded-xl border border-white/15 text-secondary hover:text-white hover:border-white/30 transition-all">
                                See The Methodology
                            </a>
                        </div>

                        <!-- Stats -->
                        <div class="grid grid-cols-3 gap-5 mt-12 pt-10 border-t border-white/8">
                            {[
                                { stat: '30+', label: 'Years IT Experience' },
                                { stat: '99.99%', label: 'Uptime Standard' },
                                { stat: '4-Phase', label: 'Protocol' },
                            ].map((item) => (
                                <div>
                                    <div class="text-2xl font-extrabold text-white">{item.stat}</div>
                                    <div class="text-xs text-secondary mt-1">{item.label}</div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Video -->
                    <div class="relative">
                        <div class="absolute inset-0 bg-cyan-500/8 rounded-3xl blur-3xl -z-10 scale-105" />
                        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-cyan-500/10">
                            <ProductVideoPlayer id="consultation" client:visible />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             THE TOOL IS NOT THE SOLUTION
        ════════════════════════════════════════════════════════ -->
        <section class="py-24 bg-[#080808] border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

                    <!-- Video LEFT -->
                    <div class="relative order-2 lg:order-1">
                        <div class="absolute inset-0 bg-cyan-500/6 rounded-3xl blur-3xl -z-10 scale-105" />
                        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-cyan-500/8">
                            <ProductVideoPlayer id="consultation-gap" client:visible />
                        </div>
                    </div>

                    <!-- Copy RIGHT -->
                    <div class="order-1 lg:order-2">
                        <span class="text-cyan-400 font-mono text-xs tracking-widest uppercase">The Architecture Gap</span>
                        <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-6 leading-tight">
                            The Tool is Not<br /><span class="text-cyan-400">The Solution.</span>
                        </h2>
                        <p class="text-secondary leading-relaxed mb-8">
                            Buying a stethoscope doesn't make you a doctor. Buying an AI Voice Agent doesn't make you automated. Without the right architecture, AI is just noise — it disconnects from your CRM, hallucinates answers, and frustrates your customers.
                        </p>

                        <div class="space-y-5">
                            {[
                                {
                                    title: 'Disconnected Tools',
                                    desc: 'Most businesses have 6+ AI tools that don\'t talk to each other. Leads fall through every gap between them.',
                                    color: 'border-red-500/30 bg-red-500/5',
                                    icon: '🔌',
                                },
                                {
                                    title: 'No Business Logic',
                                    desc: 'Off-the-shelf AI doesn\'t know your sales process, your objections, or your customer lifecycle. It guesses.',
                                    color: 'border-orange-500/30 bg-orange-500/5',
                                    icon: '🎲',
                                },
                                {
                                    title: 'Security Blind Spots',
                                    desc: 'Rushed AI installs create API vulnerabilities and data leakage risks that most vendors never mention.',
                                    color: 'border-yellow-500/30 bg-yellow-500/5',
                                    icon: '🔓',
                                },
                            ].map((item) => (
                                <div class={`rounded-xl border p-5 ${item.color}`}>
                                    <div class="flex items-start gap-4">
                                        <span class="text-xl flex-shrink-0 mt-0.5">{item.icon}</span>
                                        <div>
                                            <h3 class="font-bold text-white mb-2">{item.title}</h3>
                                            <p class="text-sm text-secondary leading-relaxed">{item.desc}</p>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             THE 4-PHASE PROTOCOL
        ════════════════════════════════════════════════════════ -->
        <section id="methodology" class="py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The SystemPros Protocol</span>
                    <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-4">
                        The <span class="text-gradient">4-Phase Integration Protocol</span>
                    </h2>
                    <p class="text-secondary max-w-xl mx-auto">Our proprietary methodology for secure, high-impact AI deployment. We don't guess. We engineer.</p>
                </div>

                <div class="grid md:grid-cols-2 gap-6 max-w-5xl mx-auto">
                    {[
                        {
                            phase: 'PHASE 1',
                            title: 'The Forensic Audit',
                            desc: 'We analyze your call logs, listen to your sales calls, and map your current failure points to find the highest-ROI opportunities. No assumptions.',
                            color: 'border-cyan-500/30 bg-cyan-500/5',
                            badge: 'text-cyan-400',
                            icon: '🔬',
                            detail: 'Detailed audit report + failure map included',
                        },
                        {
                            phase: 'PHASE 2',
                            title: 'The Neural Blueprint',
                            desc: 'We verify the logic before writing a single line of code. A custom neural workflow map handling every objection, integration, and edge case.',
                            color: 'border-blue-500/30 bg-blue-500/5',
                            badge: 'text-blue-400',
                            icon: '🗺',
                            detail: 'Visual workflow diagram delivered for sign-off',
                        },
                        {
                            phase: 'PHASE 3',
                            title: 'The Integration Build',
                            desc: 'We build the secure API pipes, configure the database schemas, and stress-test voice latency for sub-500ms response times. 30 years of IT experience here.',
                            color: 'border-purple-500/30 bg-purple-500/5',
                            badge: 'text-purple-400',
                            icon: '⚙️',
                            detail: 'Full build + QA + security testing',
                        },
                        {
                            phase: 'PHASE 4',
                            title: 'Go Live & Scale',
                            desc: 'We launch — but we don\'t leave. Real-time conversation analytics, prompt fine-tuning from live data, and white-glove support as you scale.',
                            color: 'border-green-500/30 bg-green-500/5',
                            badge: 'text-green-400',
                            icon: '🚀',
                            detail: '30-day post-launch monitoring included',
                        },
                    ].map((item) => (
                        <div class={`glass-card group hover:-translate-y-1 transition-all duration-300 border ${item.color}`}>
                            <div class="flex items-start gap-5">
                                <span class="text-2xl flex-shrink-0">{item.icon}</span>
                                <div class="flex-1">
                                    <div class={`text-xs font-bold tracking-widest uppercase mb-2 ${item.badge}`}>{item.phase}</div>
                                    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-accent transition-colors">{item.title}</h3>
                                    <p class="text-sm text-secondary leading-relaxed mb-4">{item.desc}</p>
                                    <div class="flex items-center gap-2">
                                        <div class="w-1.5 h-1.5 rounded-full bg-accent flex-shrink-0" />
                                        <span class="text-xs text-accent font-semibold">{item.detail}</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             THE SYSTEMPROS STANDARD (2-col)
        ════════════════════════════════════════════════════════ -->
        <section class="py-24 bg-[#080808] border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

                    <!-- Copy LEFT -->
                    <div>
                        <span class="text-accent font-mono text-xs tracking-widest uppercase">The SystemPros Standard</span>
                        <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-6 leading-tight">
                            Built by Engineers,<br /><span class="text-gradient">Not Marketers.</span>
                        </h2>
                        <p class="text-lg text-white/90 leading-relaxed mb-6">
                            Most AI agencies were started 6 months ago by marketers chasing a trend. SystemPros is led by 30-year IT veterans who understand data sovereignty, API security, and uptime reliability.
                        </p>
                        <p class="text-secondary leading-relaxed mb-8">
                            We don't "move fast and break things." We build critical infrastructure that lasts. When you hire us, you aren't just getting a prompt engineer — you are getting an Enterprise Solutions Architect.
                        </p>
                        <div class="space-y-4">
                            {[
                                { icon: '🔐', label: 'SOC-2 Compliant Security Practices' },
                                { icon: '🟢', label: '99.99% Uptime Architecture Standard' },
                                { icon: '🌏', label: 'Architected for NZ, Australia & USA compliance' },
                                { icon: '⚖️', label: 'GDPR & CCPA-aware data residency planning' },
                            ].map((item) => (
                                <div class="flex items-center gap-3">
                                    <span class="text-lg">{item.icon}</span>
                                    <span class="text-white/80 font-medium">{item.label}</span>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Stats RIGHT -->
                    <div class="grid grid-cols-2 gap-5">
                        {[
                            { stat: '30+', label: 'Years IT Experience', sub: 'Enterprise architecture' },
                            { stat: '99.99%', label: 'Uptime Standard', sub: 'Mission-critical builds' },
                            { stat: '3', label: 'Regions', sub: 'NZ · AU · USA' },
                            { stat: '4', label: 'Phase Protocol', sub: 'Audit to scale' },
                        ].map((item) => (
                            <div class="glass-card text-center p-7">
                                <div class="text-3xl font-extrabold text-accent mb-1">{item.stat}</div>
                                <div class="text-sm font-semibold text-white">{item.label}</div>
                                <div class="text-xs text-secondary mt-1">{item.sub}</div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             PACKAGES
        ════════════════════════════════════════════════════════ -->
        <section class="py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">Investment</span>
                    <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-4">
                        Choose Your <span class="text-gradient">Level of Support</span>
                    </h2>
                    <p class="text-secondary max-w-xl mx-auto">From strategic maps to full-service execution.</p>
                </div>

                <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                    <!-- Blueprint -->
                    <div class="glass-card p-10 flex flex-col hover:border-white/25 transition-all">
                        <div class="text-xs font-mono text-secondary tracking-widest uppercase border border-white/10 px-3 py-1 rounded bg-white/5 self-start mb-6">Strategy Only</div>
                        <h3 class="text-2xl font-bold mb-2 text-white">The Blueprint</h3>
                        <p class="text-secondary mb-8 leading-relaxed">Ideal for internal IT teams who need a plan but want to build it themselves.</p>
                        <ul class="space-y-3 mb-8 border-t border-white/8 pt-8">
                            {['Forensic Audit PDF Report', 'Custom Neural Workflow Map', 'API Specification Sheet'].map((item) => (
                                <li class="flex items-center gap-3 text-sm text-white/80">
                                    <span class="text-accent">✓</span> {item}
                                </li>
                            ))}
                        </ul>
                        <div class="mt-auto">
                            <div class="text-xl font-bold text-white mb-4">One-Time Fee</div>
                            <a href="/contact" class="inline-flex w-full justify-center items-center gap-2 px-6 py-3 rounded-xl border border-white/20 hover:bg-white/5 hover:border-white/35 transition-all font-semibold text-white">
                                Book Strategy Call
                            </a>
                        </div>
                    </div>

                    <!-- Turnkey — highlighted -->
                    <div class="glass-card p-10 flex flex-col border-accent/50 relative overflow-hidden shadow-[0_0_50px_rgba(59,130,246,0.12)]">
                        <div class="absolute top-0 right-0 bg-accent text-white text-xs font-bold px-4 py-1.5 rounded-bl-xl">MOST POPULAR</div>
                        <div class="absolute inset-0 bg-accent/[0.04] pointer-events-none" />
                        <div class="text-xs font-mono text-accent tracking-widest uppercase border border-accent/25 px-3 py-1 rounded bg-accent/10 self-start mb-6 relative z-10">Done-For-You</div>
                        <h3 class="text-2xl font-bold mb-2 text-white relative z-10">The Turnkey Integration</h3>
                        <p class="text-white/80 mb-8 leading-relaxed relative z-10">Ideal for business owners who want results installed perfectly without the headache.</p>
                        <ul class="space-y-3 mb-8 border-t border-white/8 pt-8 relative z-10">
                            {[
                                'Full Build & Configuration',
                                'The Revenue Triad Setup',
                                'Staff Training Workshop',
                                '30-Day White Glove Support',
                            ].map((item) => (
                                <li class="flex items-center gap-3 text-sm text-white font-medium">
                                    <span class="text-accent">✓</span> {item}
                                </li>
                            ))}
                        </ul>
                        <div class="mt-auto relative z-10">
                            <div class="text-xl font-bold text-accent mb-4">Custom Quote</div>
                            <a href="/contact" class="btn-primary w-full flex justify-center items-center shadow-[0_0_20px_rgba(59,130,246,0.4)]">
                                Apply For Access
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             FINAL CTA
        ════════════════════════════════════════════════════════ -->
        <section class="py-32 relative text-center overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(34,211,238,0.12)_0%,transparent_65%)]" />
            <div class="container mx-auto px-4 relative z-10 max-w-3xl">
                <h2 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tighter leading-tight">
                    Ready to stop playing<br />with tools and<br />
                    <span class="text-gradient">start building a system?</span>
                </h2>
                <p class="text-xl text-secondary mb-12 leading-relaxed max-w-2xl mx-auto">
                    After your audit, we can deploy <a href="/voice-ai" class="text-accent hover:underline">The Revenue Triad</a>, build a <a href="/lead-gen-websites" class="text-accent hover:underline">Lead Gen Website</a>, set up <a href="/lead-reactor" class="text-accent hover:underline">The Lead Reactor</a>, or configure <a href="/private-assistant" class="text-accent hover:underline">The Private Assistant</a>.
                </p>
                <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
                    Schedule Your Forensic Audit
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
            </div>
        </section>

    </main>
    <Footer />
</Layout>
