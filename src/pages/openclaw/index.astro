---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';

const subPages = [
  { title: 'OpenClaw Use Cases', desc: '10 real-world ways businesses are using OpenClaw right now.', href: '/openclaw/use-cases', icon: '💡' },
  { title: 'OpenClaw for Business', desc: 'How OpenClaw becomes your always-on AI employee.', href: '/openclaw/for-business', icon: '🏢' },
  { title: 'OpenClaw vs ChatGPT', desc: 'Why privacy-first businesses are making the switch.', href: '/openclaw/vs-chatgpt', icon: '⚔️' },
  { title: 'OpenClaw Skills Guide', desc: '3,000+ skills on ClawHub — what they are and how to use them.', href: '/openclaw/skills', icon: '⚡' },
  { title: 'OpenClaw Setup Guide', desc: 'Why most DIY installs fail, and what to do instead.', href: '/openclaw/setup-guide', icon: '🔧' },
];
---

<Layout
  title="What is OpenClaw? The World's Most Powerful Private AI Assistant | SystemPros.ai"
  description="OpenClaw is the open-source AI assistant with 247,000+ GitHub stars. It runs on your hardware, works on 20+ messaging platforms, and never sends your data to Big Tech. Learn everything about OpenClaw here."
>
  <ServiceSchema name="OpenClaw Setup & Deployment" description="Done-for-you OpenClaw AI assistant deployment across WhatsApp, iMessage, Slack and 17 more platforms." serviceType="AIConsulting" />
  <Breadcrumbs currentTitle="What is OpenClaw?" />

  <main class="overflow-x-hidden">

    <!-- HERO -->
    <section class="relative pt-32 pb-20 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(139,92,246,0.18)_0%,transparent_60%)]" />
      <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest uppercase text-purple-400 border border-purple-500/25 bg-purple-500/5 rounded-full px-4 py-2 mb-8">
              <span class="w-1.5 h-1.5 rounded-full bg-purple-400 inline-block"></span>
              247,000+ GitHub Stars
            </div>
            <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tighter mb-6">
              What is <span class="text-gradient">OpenClaw?</span>
            </h1>
            <p class="text-lg text-secondary leading-relaxed mb-6">
              OpenClaw is the world's fastest-growing open-source AI assistant — a personal AI that lives on <strong class="text-white">your hardware</strong>, works on <strong class="text-white">20+ messaging platforms</strong>, and never sends your data to someone else's servers.
            </p>
            <p class="text-secondary leading-relaxed mb-10">
              Unlike ChatGPT or Claude's web interface, OpenClaw is installed privately on your Mac, Linux server, or cloud VM. You message it on WhatsApp, iMessage, Slack, or Discord — and it responds instantly, remembers everything, and acts as your personal executive assistant, researcher, and automation engine.
            </p>
            <div class="flex flex-wrap gap-4">
              <a href="/private-assistant" class="btn-primary inline-flex items-center gap-2 px-8 py-4">
                Get It Deployed For Me
              </a>
              <a href="/openclaw/setup-guide" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl border border-white/15 text-secondary hover:text-white hover:border-white/30 transition-all">
                DIY Setup Guide
              </a>
            </div>
          </div>
          <div class="relative">
            <div class="absolute inset-0 bg-purple-500/10 rounded-3xl blur-3xl -z-10 scale-105" />
            <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-purple-500/10">
              <ProductVideoPlayer id="openclaw-hub" client:visible />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- WHAT MAKES IT DIFFERENT -->
    <section class="py-20 bg-[#080808] border-y border-white/5">
      <div class="container mx-auto px-4 max-w-4xl">
        <h2 class="text-3xl md:text-4xl font-bold mb-8 text-center">Why OpenClaw is <span class="text-gradient">Different</span></h2>
        <div class="prose prose-invert prose-lg max-w-none text-secondary leading-relaxed space-y-5">
          <p>
            Most AI tools follow the same model: you go to a website, type a question, get an answer, and the conversation resets. Every query you make is logged, analysed, and potentially used to train future models. Your business strategies, your client names, your revenue figures — all of it flows through someone else's cloud.
          </p>
          <p>
            OpenClaw breaks this model entirely. It's an <strong class="text-white">open-source framework</strong> that you (or we) install on your own hardware. Once running, it connects to the messaging apps you already use — WhatsApp, iMessage, Slack, Discord, Telegram — so your AI is literally a contact in your phone. You text it. It responds. And everything stays within your four walls.
          </p>
          <p>
            The "<strong class="text-white">Claw</strong>" in OpenClaw refers to the system's core philosophy: an AI that grabs onto your existing workflows and holds on. It doesn't replace your tools — it becomes the intelligent layer that connects them all.
          </p>
          <p>
            With <strong class="text-white">3,000+ community skills on ClawHub</strong> (think of it as an app store for AI capabilities), you can extend OpenClaw to handle anything from summarising Zoom calls to updating your CRM, querying your Obsidian notes, or running competitive research in real time.
          </p>
        </div>
      </div>
    </section>

    <!-- KEY FEATURES -->
    <section class="py-20">
      <div class="container mx-auto px-4 max-w-5xl">
        <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Core <span class="text-gradient">Features</span></h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {[
            { icon: '🔐', title: 'Fully Private', desc: 'Runs on your hardware. Your data never leaves your device. No cloud logging, no model training on your conversations.' },
            { icon: '📱', title: '20+ Platforms', desc: 'WhatsApp, iMessage, Slack, Discord, Telegram, Teams, Signal, and more. One AI across every channel you use.' },
            { icon: '🧠', title: 'Persistent Memory', desc: 'Remembers context across weeks and months. Ask "what did I say about that client last Tuesday?" — it knows.' },
            { icon: '⚡', title: '3,000+ Skills', desc: 'Install skills from ClawHub to extend capabilities: web search, CRM updates, note querying, image generation, and more.' },
            { icon: '🧬', title: 'Custom SOUL.md', desc: 'A personality file that defines how your AI thinks, communicates, and behaves. It genuinely sounds like you.' },
            { icon: '🔄', title: 'Proactive Automation', desc: 'Set cron-style triggers so your AI proactively sends reminders, summaries, or updates without being asked.' },
          ].map((f) => (
            <div class="glass-card group hover:-translate-y-1 transition-all duration-300">
              <span class="text-2xl mb-3 block">{f.icon}</span>
              <h3 class="font-bold text-white mb-2 group-hover:text-accent transition-colors">{f.title}</h3>
              <p class="text-sm text-secondary leading-relaxed">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- EXPLORE HUB -->
    <section class="py-20 bg-[#080808] border-y border-white/5">
      <div class="container mx-auto px-4 max-w-5xl">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Explore the <span class="text-gradient">OpenClaw Hub</span></h2>
          <p class="text-secondary max-w-xl mx-auto">Everything you need to understand, evaluate, and deploy OpenClaw for your business.</p>
        </div>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
          {subPages.map((page) => (
            <a href={page.href} class="glass-card group hover:-translate-y-1 hover:border-accent/30 transition-all duration-300 flex flex-col">
              <span class="text-2xl mb-3 block">{page.icon}</span>
              <h3 class="font-bold text-white mb-2 group-hover:text-accent transition-colors">{page.title}</h3>
              <p class="text-sm text-secondary leading-relaxed mb-4 flex-1">{page.desc}</p>
              <div class="flex items-center gap-1.5 text-accent text-xs font-semibold">
                Read Guide
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-28 relative text-center overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(139,92,246,0.14)_0%,transparent_65%)]" />
      <div class="container mx-auto px-4 relative z-10 max-w-3xl">
        <h2 class="text-4xl md:text-5xl font-extrabold mb-6 tracking-tighter">
          Want OpenClaw Running<br /><span class="text-gradient">on Your Devices in 48 Hours?</span>
        </h2>
        <p class="text-xl text-secondary mb-10 leading-relaxed">We handle installation, channel connections, SOUL.md personality, and skill setup. You get a production-ready private AI assistant without touching a terminal.</p>
        <a href="/private-assistant" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
          See The Private Assistant Service
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
