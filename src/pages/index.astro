---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import VideoShowcase from '../components/VideoShowcase.jsx';
---

<Layout
	title="SystemPros.ai | AI Integration, Voice AI, Lead Gen & Automation"
	description="6 AI-powered solutions for ambitious businesses: Voice AI agents, lead gen websites, paid ads automation, personal AI assistants, consulting, and training. Engineered for NZ, Australia, and the USA."
>

	<main>

		<!-- ============================================ -->
		<!-- 1. HERO                                      -->
		<!-- ============================================ -->
		<section class="relative min-h-screen flex flex-col items-center justify-center pt-20 pb-10 overflow-hidden bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main">
			<div class="container mx-auto px-4 z-10 flex flex-col items-center text-center max-w-5xl pointer-events-none">

				<!-- Badge -->
				<div class="pointer-events-auto fade-up inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/5 backdrop-blur-sm mb-8" style="animation-delay: 0.1s;">
					<span class="text-accent text-xs font-bold tracking-wider uppercase">6 AI Solutions. One Partner.</span>
				</div>

				<!-- H1 -->
				<h1 class="pointer-events-auto fade-up text-5xl md:text-7xl font-extrabold tracking-tighter mb-6 leading-[1.1]" style="animation-delay: 0.2s;">
					We Don't Just Sell Tools.<br />
					<span class="text-gradient">We Build Your AI Workforce.</span>
				</h1>

				<!-- Subtitle -->
				<p class="pointer-events-auto fade-up text-lg md:text-xl text-secondary max-w-2xl mb-10 leading-relaxed" style="animation-delay: 0.3s;">
					Voice AI agents, lead gen websites, automated outreach, personal AI assistants, strategic consulting, and hands-on training. Engineered for businesses in <strong class="text-white">NZ, Australia, and the USA</strong>.
				</p>

				<!-- CTAs -->
				<div class="pointer-events-auto fade-up flex flex-col sm:flex-row gap-4 w-full justify-center mb-12" style="animation-delay: 0.5s;">
					<a href="/contact" class="btn-cta flex items-center justify-center gap-2">
						Book Free Consultation
					</a>
					<a href="#command-center" class="px-8 py-4 rounded-full border border-white/10 hover:bg-white/5 hover:border-white/30 transition-all font-semibold flex items-center justify-center gap-2">
						See How It Works
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>

				<!-- Trust Stats Bar -->
				<div class="pointer-events-auto fade-up flex flex-wrap justify-center gap-6 md:gap-10" style="animation-delay: 0.7s;">
					<div class="flex items-center gap-2 text-sm">
						<span class="text-accent font-bold text-lg">30+</span>
						<span class="text-secondary">Years IT Experience</span>
					</div>
					<div class="w-px h-6 bg-white/10 hidden md:block"></div>
					<div class="flex items-center gap-2 text-sm">
						<span class="text-accent font-bold text-lg">3</span>
						<span class="text-secondary">Countries Served</span>
					</div>
					<div class="w-px h-6 bg-white/10 hidden md:block"></div>
					<div class="flex items-center gap-2 text-sm">
						<span class="text-accent font-bold text-lg">6</span>
						<span class="text-secondary">AI Solutions</span>
					</div>
					<div class="w-px h-6 bg-white/10 hidden md:block"></div>
					<div class="flex items-center gap-2 text-sm">
						<span class="text-accent font-bold text-lg">24/7</span>
						<span class="text-secondary">AI Availability</span>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================================ -->
		<!-- 2. TRUST BAR (Animated Marquee Logos)        -->
		<!-- ============================================ -->
		<section class="py-10 border-y border-white/5 bg-surface/30 overflow-hidden relative">
			<p class="text-center text-xs text-secondary/60 uppercase tracking-widest mb-8 font-medium">Built With Industry-Leading Platforms</p>

			<!-- Row 1: Scrolls Left -->
			<div class="marquee-wrapper mb-4">
				<div class="marquee-track marquee-left">
					{[...Array(2)].map(() => (
						<div class="marquee-content">
							<div class="marquee-item">
								<img src="/assets/logos/gohighlevel.webp" alt="GoHighLevel" width="97" height="25" class="marquee-logo" loading="lazy" />
								<span class="marquee-label">GoHighLevel</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/twilio.webp" alt="Twilio" width="40" height="40" class="marquee-logo-square" loading="lazy" />
								<span class="marquee-label">Twilio</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/n8n.webp" alt="N8N" width="40" height="40" class="marquee-logo-square" loading="lazy" />
								<span class="marquee-label">N8N</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/hubspot.avif" alt="HubSpot" width="97" height="25" class="marquee-logo" loading="lazy" />
								<span class="marquee-label">HubSpot</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/zapier.avif" alt="Zapier" width="40" height="40" class="marquee-logo-square" loading="lazy" />
								<span class="marquee-label">Zapier</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/salesforce.avif" alt="Salesforce" width="97" height="25" class="marquee-logo" loading="lazy" />
								<span class="marquee-label">Salesforce</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">Vapi</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">ElevenLabs</span>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Row 2: Scrolls Right -->
			<div class="marquee-wrapper">
				<div class="marquee-track marquee-right">
					{[...Array(2)].map(() => (
						<div class="marquee-content">
							<div class="marquee-item">
								<img src="/assets/logos/make.svg" alt="Make.com" width="80" height="25" class="marquee-logo" loading="lazy" />
								<span class="marquee-label">Make.com</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/vonage.webp" alt="Vonage" width="40" height="40" class="marquee-logo-square" loading="lazy" />
								<span class="marquee-label">Vonage</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/telnyx.svg" alt="Telnyx" width="97" height="25" class="marquee-logo" loading="lazy" />
								<span class="marquee-label">Telnyx</span>
							</div>
							<div class="marquee-item">
								<img src="/assets/logos/calcom.svg" alt="Cal.com" width="40" height="40" class="marquee-logo-square" loading="lazy" />
								<span class="marquee-label">Cal.com</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">OpenClaw</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">Claude</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">Google Gemini</span>
							</div>
							<div class="marquee-item">
								<span class="marquee-text-logo">Meta Ads</span>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Edge fade masks -->
			<div class="pointer-events-none absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-main to-transparent z-10"></div>
			<div class="pointer-events-none absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-main to-transparent z-10"></div>
		</section>

		<!-- ============================================ -->
		<!-- 3. VSL / COMMAND CENTER (2-Column)           -->
		<!-- ============================================ -->
		<section id="command-center" class="py-24 bg-surface/30 relative">
			<div class="container mx-auto px-4">
				<div class="flex flex-col lg:flex-row items-center gap-16">

					<!-- Video Side -->
					<div class="w-full lg:w-1/2 relative group">
						<div class="absolute inset-0 bg-accent/20 blur-[120px] rounded-full opacity-20 group-hover:opacity-40 transition-opacity duration-700"></div>

						<div class="glass-card relative rounded-xl overflow-hidden border border-white/10 shadow-[0_20px_50px_rgba(0,0,0,0.5)] transform transition-transform duration-500 hover:scale-[1.01] hover:shadow-[0_20px_50px_rgba(59,130,246,0.2)]">
							<div class="relative aspect-video bg-black">
								<video
									id="demo-video"
									src="/assets/demo-video.mp4"
									autoplay
									muted
									loop
									playsinline
									class="w-full h-full object-cover"
								></video>

								<!-- Mute Toggle -->
								<button
									id="mute-toggle"
									class="absolute bottom-4 right-4 z-30 w-12 h-12 bg-black/60 backdrop-blur-md rounded-full flex items-center justify-center border border-white/20 hover:bg-accent/40 hover:border-accent/50 transition-all duration-300 hover:scale-110 cursor-pointer"
									aria-label="Toggle sound"
								>
									<svg id="icon-muted" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
										<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
										<line x1="23" y1="9" x2="17" y2="15"></line>
										<line x1="17" y1="9" x2="23" y2="15"></line>
									</svg>
									<svg id="icon-unmuted" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white hidden">
										<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon>
										<path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path>
										<path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path>
									</svg>
								</button>
							</div>
						</div>
					</div>

					<!-- Content Side -->
					<div class="w-full lg:w-1/2 space-y-10">
						<div>
							<h2 class="text-3xl md:text-5xl font-bold mb-4 leading-tight">The All-In-One <br><span class="text-gradient">Command Center</span></h2>
							<p class="text-secondary text-lg">Replace fragmented tools with a cohesive architectural system. We design the flow, implement the nodes, and secure the data.</p>
						</div>

						<div class="space-y-8">
							<div class="flex gap-4 group">
								<div class="shrink-0 w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent group-hover:bg-accent group-hover:text-white transition-colors duration-300">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
								</div>
								<div>
									<h3 class="text-xl font-bold mb-2 text-white">AI Voice Receptionist</h3>
									<p class="text-secondary text-sm">Sounds 100% human. Qualifies leads, answers FAQs, and books appointments 24/7. Never calls in sick.</p>
								</div>
							</div>

							<div class="flex gap-4 group">
								<div class="shrink-0 w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent group-hover:bg-accent group-hover:text-white transition-colors duration-300">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
								</div>
								<div>
									<h3 class="text-xl font-bold mb-2 text-white">Smart CRM Integration</h3>
									<p class="text-secondary text-sm">Data doesn't just sit there; it moves. Automatic updates, tagging, and pipeline movement based on conversation intent.</p>
								</div>
							</div>

							<div class="flex gap-4 group">
								<div class="shrink-0 w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center text-accent group-hover:bg-accent group-hover:text-white transition-colors duration-300">
									<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
								</div>
								<div>
									<h3 class="text-xl font-bold mb-2 text-white">Visual Pipelines</h3>
									<p class="text-secondary text-sm">See exactly where every dollar is stuck. Identify bottlenecks in your sales process instantly.</p>
								</div>
							</div>
						</div>
					</div>

				</div>
			</div>
		</section>

		<!-- ============================================ -->
		<!-- 4. PRODUCTS GRID                             -->
		<!-- ============================================ -->
		<section id="products" class="py-24 relative z-10">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-bold mb-4">Our <span class="text-gradient">Solutions</span></h2>
					<p class="text-secondary max-w-xl mx-auto">Six integrated products to automate your sales, operations, and growth.</p>
				</div>

				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
					<ProductCard
						title="The Revenue Triad"
						description="3 Voice AI agents that answer calls, chase web leads instantly, and reactivate dormant clients. Your 24/7 revenue ecosystem."
						href="/voice-ai"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>'
					/>
					<ProductCard
						title="Lead Gen Websites"
						description="Transform brochure websites into lead machines. Smart forms, calendars, chat & voice widgets — all wired to automations that convert."
						href="/lead-gen-websites"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>'
					/>
					<ProductCard
						title="The Lead Reactor"
						description="Run Meta ads, we handle the rest. Instant multi-channel outreach via iMessage, WhatsApp, SMS & calling until they book."
						href="/lead-reactor"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>'
					/>
					<ProductCard
						title="The Private Assistant"
						description="A done-for-you OpenClaw AI assistant on WhatsApp, Telegram, Slack & more. 3,000+ skills, persistent memory, built for you."
						href="/private-assistant"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>'
					/>
					<ProductCard
						title="Consultation"
						description="A forensic audit of your operations followed by a strategic AI roadmap. 30 years of IT architecture applied to your business."
						href="/consulting"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>'
					/>
					<ProductCard
						title="Training"
						description="1-on-1 sessions on AI agents, Claude Code, GoHighLevel, N8N, Make.com, Voice AI, OpenClaw & more. Pure hands-on application."
						href="/training"
						icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>'
					/>
				</div>
			</div>
		</section>

		<!-- ============================================ -->
		<!-- 5. VIDEO SHOWCASE (Industry Demos)           -->
		<!-- ============================================ -->
		<section class="py-24 relative overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-b from-transparent via-blue-900/10 to-transparent pointer-events-none"></div>
			<div class="container mx-auto px-4 relative z-10">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-bold mb-4">See It <span class="text-gradient">In Action</span></h2>
					<p class="text-secondary max-w-xl mx-auto">Real AI assistants. Real conversations. Watch how we transform businesses across industries.</p>
				</div>
				<VideoShowcase client:visible />
			</div>
		</section>

		<!-- ============================================ -->
		<!-- 6. TESTIMONIALS                              -->
		<!-- ============================================ -->
		<section class="py-24 bg-[#080808]">
			<div class="container mx-auto px-4">
				<div class="text-center mb-16">
					<h2 class="text-3xl md:text-5xl font-bold mb-4">What Our Clients <span class="text-gradient">Say</span></h2>
					<p class="text-secondary max-w-xl mx-auto">Businesses across NZ, Australia, and the USA trust SystemPros to build their AI infrastructure.</p>
				</div>

				<div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
					<!-- Testimonial 1 -->
					<div class="glass-card relative">
						<!-- Quote mark -->
						<div class="text-accent/20 text-6xl font-serif leading-none mb-4">"</div>
						<p class="text-secondary leading-relaxed mb-8">
							SystemPros didn't just give us a chatbot. They rebuilt our entire intake process. We went from missing 60% of calls to capturing every single lead — automatically. The ROI was visible in week one.
						</p>
						<div class="flex items-center gap-3 mt-auto">
							<div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-sm">JR</div>
							<div>
								<div class="text-sm font-semibold text-white">James R.</div>
								<div class="text-xs text-secondary">Roofing Company Owner, Auckland</div>
							</div>
						</div>
					</div>

					<!-- Testimonial 2 -->
					<div class="glass-card relative">
						<div class="text-accent/20 text-6xl font-serif leading-none mb-4">"</div>
						<p class="text-secondary leading-relaxed mb-8">
							The Lead Reactor completely changed our ad game. We were spending $5K/mo on Meta ads with manual follow-up. Now every lead gets a call within 10 seconds. Our cost per acquisition dropped by 40%.
						</p>
						<div class="flex items-center gap-3 mt-auto">
							<div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-sm">SP</div>
							<div>
								<div class="text-sm font-semibold text-white">Sarah P.</div>
								<div class="text-xs text-secondary">Dental Practice Manager, Sydney</div>
							</div>
						</div>
					</div>

					<!-- Testimonial 3 -->
					<div class="glass-card relative">
						<div class="text-accent/20 text-6xl font-serif leading-none mb-4">"</div>
						<p class="text-secondary leading-relaxed mb-8">
							The training sessions on Claude Code and N8N were game-changing for our team. We went from zero AI capability to building our own automations in two weeks. Highly recommend the 1-on-1 format.
						</p>
						<div class="flex items-center gap-3 mt-auto">
							<div class="w-10 h-10 rounded-full bg-accent/20 flex items-center justify-center text-accent font-bold text-sm">MK</div>
							<div>
								<div class="text-sm font-semibold text-white">Michael K.</div>
								<div class="text-xs text-secondary">Agency Founder, New York</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================================ -->
		<!-- 7. BRIDGE CTA (Trust + Experience)           -->
		<!-- ============================================ -->
		<section class="py-32 relative text-center overflow-hidden">
			<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>
			<div class="container mx-auto px-4 relative z-10 max-w-3xl">
				<h2 class="text-4xl md:text-6xl font-extrabold mb-8 tracking-tighter">Why 30 Years of IT Experience Matters.</h2>
				<p class="text-xl text-secondary mb-12 leading-relaxed">
					AI is powerful, but dangerous if unconnected. Unlike generic agencies, we don't just turn it on; we integrate it securely into your systems using 3 decades of enterprise architecture experience.
				</p>
				<div class="flex flex-wrap justify-center gap-6 mb-12">
					<div class="flex items-center gap-2 text-sm font-mono text-accent bg-accent/10 px-4 py-2 rounded border border-accent/20">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
						<span>Enterprise Security</span>
					</div>
