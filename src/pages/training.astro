---
import Layout from '../layouts/Layout.astro';
import ProductHero from '../components/ProductHero.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import ProductVideoPlayer from '../components/ProductVideoPlayer';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';
import trainingHero from '../assets/training_hero.png';

const topics = [
    { title: 'AI Fundamentals', desc: 'Prompting, models, context windows, and how to think about AI as a tool. The foundation everything else builds on.', color: 'text-blue-400' },
    { title: 'AI Agents', desc: 'Building autonomous workflows that execute multi-step tasks. Understand agent loops, tool use, and orchestration.', color: 'text-cyan-400' },
    { title: 'Claude Code', desc: "Anthropic's AI coding tool. Learn to use it for code generation, debugging, refactoring, and full-project development.", color: 'text-purple-400' },
    { title: 'GoHighLevel', desc: 'CRM, funnels, automations, and pipeline management. The all-in-one platform for agencies and service businesses.', color: 'text-green-400' },
    { title: 'N8N', desc: 'Self-hosted workflow automation. Connect APIs, build complex logic, and automate anything without vendor lock-in.', color: 'text-orange-400' },
    { title: 'Make.com', desc: 'Visual automation for non-developers. Build powerful integrations with drag-and-drop scenarios.', color: 'text-pink-400' },
    { title: 'Image & Generative AI', desc: 'Midjourney, DALL-E, Gemini image generation. Create professional visuals, product mockups, and marketing assets.', color: 'text-yellow-400' },
    { title: 'Voice AI Agents', desc: 'Build and deploy voice AI receptionists and outbound callers using Vapi, ElevenLabs, and custom integrations.', color: 'text-red-400' },
    { title: 'OpenClaw', desc: 'Set up, configure, and extend your personal AI assistant. Skills, SOUL.md, integrations, and automation.', color: 'text-teal-400' },
];

const faqs = [
    { question: 'How are training sessions delivered?', answer: '1-on-1 via video call (Zoom or Google Meet). We share screens, build together in real-time, and record the session for you to review later.' },
    { question: 'Do I need technical experience?', answer: 'No. We tailor each session to your level. Whether you\'re a complete beginner or an experienced developer, we meet you where you are.' },
    { question: 'Can I book training for my team?', answer: 'Yes. We offer team training sessions and can create custom curricula for your organization. Contact us for team pricing.' },
    { question: 'How long is each session?', answer: 'Standard sessions are 60-90 minutes. We focus on hands-on application, not lectures. You build real things in every session.' },
];
---

<Layout
    title="1-on-1 AI Training | Claude Code, GoHighLevel, N8N, Voice AI & More | SystemPros.ai"
    description="Hands-on 1-on-1 training sessions on AI agents, Claude Code, GoHighLevel, N8N, Make.com, Voice AI, OpenClaw, and generative AI tools. From people who build with them daily."
>
    <ServiceSchema name="AI Training" description="1-on-1 hands-on training sessions covering AI fundamentals, AI agents, Claude Code, GoHighLevel, N8N, Make.com, Voice AI, and OpenClaw." serviceType="EducationalService" />
    <FAQSchema faqs={faqs} />
    <Breadcrumbs currentTitle="Training" />

    <main class="overflow-x-hidden">

        <!-- Hero -->
        <ProductHero
            badge="1-on-1 Training"
            title='Learn AI.<br /><span class="text-gradient">From People Who Build With It Every Day.</span>'
            subtitle="Hands-on training sessions covering the tools and platforms driving real results right now. No theory — pure application."
            ctaText="Book a Training Session"
            ctaLink="/contact"
            secondaryCtaText="View Pricing"
            secondaryCtaLink="/pricing"
            heroImage={trainingHero}
            heroImageAlt="AI training and workshop"
        />

        <!-- Curriculum Grid -->
        <section class="py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">What You Can <span class="text-gradient">Learn</span></h2>
                    <p class="text-secondary max-w-xl mx-auto">Pick one topic or build a custom curriculum across multiple. Every session is tailored to your goals.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
                    {topics.map((topic) => (
                        <div class="glass-card group hover:-translate-y-1 transition-all duration-300">
                            <div class={`text-xs font-mono tracking-widest uppercase mb-3 ${topic.color}`}>{topic.title}</div>
                            <p class="text-sm text-secondary leading-relaxed">{topic.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- MOTION INFOGRAPHIC VIDEO -->
        <section class="py-20 bg-[#060606]">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The Curriculum Visualized</span>
                    <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-3">What You'll <span class="text-gradient">Master</span></h2>
                    <p class="text-secondary max-w-xl mx-auto">6 tools, skill-by-skill progress, and 1-on-1 sessions tailored to your exact business needs.</p>
                </div>
                <div class="max-w-md mx-auto rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-blue-500/10">
                    <ProductVideoPlayer id="training" client:visible />
                </div>
            </div>
        </section>

        <!-- How It Works -->
        <section class="py-24 bg-surface/30 border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">How It <span class="text-gradient">Works</span></h2>
                </div>

                <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    {[
                        { step: '01', title: 'Book a Session', desc: 'Pick a time that works for you. Tell us what you want to learn and your current skill level.' },
                        { step: '02', title: 'Custom Curriculum', desc: 'We prepare a hands-on session tailored to your goals. No generic slides — everything is built around your use case.' },
                        { step: '03', title: 'Build Together', desc: 'Live 1-on-1 session via video call. We build real things together. You leave with working knowledge and recorded material.' },
                    ].map((item) => (
                        <div class="glass-card text-center group hover:-translate-y-2 transition-all duration-300">
                            <div class="text-5xl font-extrabold text-accent/20 mb-4 group-hover:text-accent/40 transition-colors">{item.step}</div>
                            <h3 class="text-xl font-bold mb-3 text-white">{item.title}</h3>
                            <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Who It's For -->
        <section class="py-24">
            <div class="container mx-auto px-4 text-center">
                <h2 class="text-3xl md:text-4xl font-bold mb-12">Who It's <span class="text-gradient">For</span></h2>

                <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
                    {['Founders & CEOs', 'Marketing Teams', 'Operations Managers', 'Developers', 'Freelancers', 'Agency Owners', 'Sales Teams', 'Content Creators'].map((audience) => (
                        <div class="px-6 py-3 rounded-full bg-surface/80 border border-white/10 text-sm font-medium text-white hover:border-accent/40 hover:bg-accent/5 transition-all">
                            {audience}
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- FAQ -->
        <section class="py-24 bg-[#080808]">
            <div class="container mx-auto px-4 max-w-3xl">
                <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Frequently Asked <span class="text-gradient">Questions</span></h2>

                <div class="space-y-4">
                    {faqs.map((faq) => (
                        <details class="glass-card cursor-pointer group" open={false}>
                            <summary class="font-bold text-white list-none flex items-center justify-between">
                                {faq.question}
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-secondary group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"/></svg>
                            </summary>
                            <p class="text-secondary mt-4 leading-relaxed">{faq.answer}</p>
                        </details>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-32 relative text-center overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>
            <div class="container mx-auto px-4 relative z-10 max-w-3xl">
                <h2 class="text-4xl md:text-6xl font-extrabold mb-8 tracking-tighter">Stop Watching Tutorials.<br/><span class="text-gradient">Start Building.</span></h2>
                <p class="text-xl text-secondary mb-12 leading-relaxed">
                    Learn from practitioners, not theorists. Book your first session today.
                </p>
                <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
                    Book a Training Session
                </a>
            </div>
        </section>

    </main>
    <Footer />
</Layout>
