---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import ProductVideoPlayer from '../components/ProductVideoPlayer';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';

const topics = [
    { title: 'AI Fundamentals', desc: 'Prompting, models, context windows, and how to think about AI as a tool. The foundation everything else builds on.', color: 'text-blue-400', border: 'border-blue-500/20', bg: 'bg-blue-500/5' },
    { title: 'AI Agents', desc: 'Building autonomous workflows that execute multi-step tasks. Understand agent loops, tool use, and orchestration.', color: 'text-cyan-400', border: 'border-cyan-500/20', bg: 'bg-cyan-500/5' },
    { title: 'Claude Code', desc: "Anthropic's AI coding tool. Code generation, debugging, refactoring, and full-project development.", color: 'text-purple-400', border: 'border-purple-500/20', bg: 'bg-purple-500/5' },
    { title: 'GoHighLevel', desc: 'CRM, funnels, automations, and pipeline management. The all-in-one platform for agencies and service businesses.', color: 'text-green-400', border: 'border-green-500/20', bg: 'bg-green-500/5' },
    { title: 'N8N', desc: 'Self-hosted workflow automation. Connect APIs, build complex logic, and automate anything without vendor lock-in.', color: 'text-orange-400', border: 'border-orange-500/20', bg: 'bg-orange-500/5' },
    { title: 'Make.com', desc: 'Visual automation for non-developers. Build powerful integrations with drag-and-drop scenarios.', color: 'text-pink-400', border: 'border-pink-500/20', bg: 'bg-pink-500/5' },
    { title: 'Image & Generative AI', desc: 'Midjourney, DALL-E, Gemini image generation. Create professional visuals and marketing assets.', color: 'text-yellow-400', border: 'border-yellow-500/20', bg: 'bg-yellow-500/5' },
    { title: 'Voice AI Agents', desc: 'Build and deploy voice AI receptionists and outbound callers using Vapi, ElevenLabs, and custom integrations.', color: 'text-red-400', border: 'border-red-500/20', bg: 'bg-red-500/5' },
    { title: 'OpenClaw', desc: 'Set up, configure, and extend your personal AI assistant. Skills, SOUL.md, integrations, and automation.', color: 'text-teal-400', border: 'border-teal-500/20', bg: 'bg-teal-500/5' },
];

const faqs = [
    { question: 'How are training sessions delivered?', answer: '1-on-1 via video call (Zoom or Google Meet). We share screens, build together in real-time, and record the session for you to review later.' },
    { question: 'Do I need technical experience?', answer: "No. We tailor each session to your level. Whether you're a complete beginner or an experienced developer, we meet you where you are." },
    { question: 'Can I book training for my team?', answer: 'Yes. We offer team training sessions and can create custom curricula for your organization. Contact us for team pricing.' },
    { question: 'How long is each session?', answer: 'Standard sessions are 60-90 minutes. We focus on hands-on application, not lectures. You build real things in every session.' },
];
---

<Layout
    title="1-on-1 AI Training | Claude Code, GoHighLevel, N8N, Voice AI & More | SystemPros.ai"
    description="Hands-on 1-on-1 training on AI agents, Claude Code, GoHighLevel, N8N, Make.com, Voice AI, and OpenClaw. No theory — pure application from people who build with these tools every day."
>
    <ServiceSchema name="AI Training" description="1-on-1 hands-on training sessions covering AI fundamentals, AI agents, Claude Code, GoHighLevel, N8N, Make.com, Voice AI, and OpenClaw." serviceType="EducationalService" />
    <FAQSchema faqs={faqs} />
    <Breadcrumbs currentTitle="Training" />

    <main class="overflow-x-hidden">

        <!-- ════════════════════════════════════════════════════════
             HERO
        ════════════════════════════════════════════════════════ -->
        <section class="relative pt-32 pb-24 overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(34,197,94,0.15)_0%,transparent_60%)]" />
            <div class="container mx-auto px-4 relative z-10">
                <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

                    <!-- Copy -->
                    <div>
                        <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest uppercase text-green-400 border border-green-500/25 bg-green-500/5 rounded-full px-4 py-2 mb-8">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block"></span>
                            1-on-1 Training
                        </div>

                        <h1 class="text-4xl md:text-6xl font-extrabold leading-tight tracking-tighter mb-6">
                            Learn AI.<br />
                            <span class="text-gradient">From People Who<br />Build With It Every Day.</span>
                        </h1>

                        <p class="text-lg text-secondary leading-relaxed mb-10 max-w-xl">
                            Hands-on training sessions covering the tools and platforms driving real results right now. No theory — pure application. You build real things in every session.
                        </p>

                        <div class="flex flex-wrap gap-4">
                            <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-base px-8 py-4">
                                Book a Training Session
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </a>
                            <a href="#curriculum" class="inline-flex items-center gap-2 text-base px-8 py-4 rounded-xl border border-white/15 text-secondary hover:text-white hover:border-white/30 transition-all">
                                See All 9 Topics
                            </a>
                        </div>

                        <!-- Stats -->
                        <div class="grid grid-cols-3 gap-5 mt-12 pt-10 border-t border-white/8">
                            {[
                                { stat: '9', label: 'Topics Available' },
                                { stat: '60–90', label: 'Min Sessions' },
                                { stat: '1-on-1', label: 'Every Session' },
                            ].map((item) => (
                                <div>
                                    <div class="text-2xl font-extrabold text-white">{item.stat}</div>
                                    <div class="text-xs text-secondary mt-1">{item.label}</div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Video -->
                    <div class="relative">
                        <div class="absolute inset-0 bg-green-500/8 rounded-3xl blur-3xl -z-10 scale-105" />
                        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-green-500/10">
                            <ProductVideoPlayer id="training" client:visible />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             THE PROBLEM — Tutorial Hell
        ════════════════════════════════════════════════════════ -->
        <section class="py-24 bg-[#080808] border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">

                    <!-- Video LEFT -->
                    <div class="relative order-2 lg:order-1">
                        <div class="absolute inset-0 bg-green-500/6 rounded-3xl blur-3xl -z-10 scale-105" />
                        <div class="rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-green-500/8">
                            <ProductVideoPlayer id="training-results" client:visible />
                        </div>
                    </div>

                    <!-- Copy RIGHT -->
                    <div class="order-1 lg:order-2">
                        <span class="text-red-400 font-mono text-xs tracking-widest uppercase">The Problem</span>
                        <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-6 leading-tight">
                            Stop Drowning in<br /><span class="text-red-400">Tutorial Hell.</span>
                        </h2>
                        <p class="text-secondary leading-relaxed mb-8">
                            You've watched the YouTube videos. You've bought the courses. But you're still not automating anything. The problem isn't effort — it's the learning format.
                        </p>

                        <div class="space-y-5">
                            {[
                                {
                                    title: 'Generic Content, Not Your Use Case',
                                    desc: 'Every tutorial teaches a toy example that has nothing to do with your actual business. You\'re left translating theory to practice — alone.',
                                    color: 'border-red-500/30 bg-red-500/5',
                                    icon: '📺',
                                },
                                {
                                    title: 'No Real Application',
                                    desc: 'Watching someone else build something is not the same as building it yourself. You forget 80% within 48 hours if you didn\'t apply it live.',
                                    color: 'border-orange-500/30 bg-orange-500/5',
                                    icon: '🧠',
                                },
                                {
                                    title: 'Tools Change Fast',
                                    desc: 'AI tools update weekly. By the time a course ships, half the UI has changed and the techniques are already outdated. We teach what\'s live now.',
                                    color: 'border-yellow-500/30 bg-yellow-500/5',
                                    icon: '⚡',
                                },
                            ].map((item) => (
                                <div class={`rounded-xl border p-5 ${item.color}`}>
                                    <div class="flex items-start gap-4">
                                        <span class="text-xl flex-shrink-0 mt-0.5">{item.icon}</span>
                                        <div>
                                            <h3 class="font-bold text-white mb-2">{item.title}</h3>
                                            <p class="text-sm text-secondary leading-relaxed">{item.desc}</p>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             CURRICULUM GRID
        ════════════════════════════════════════════════════════ -->
        <section id="curriculum" class="py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The Curriculum</span>
                    <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-4">
                        What You Can <span class="text-gradient">Learn</span>
                    </h2>
                    <p class="text-secondary max-w-xl mx-auto">Pick one topic or build a custom curriculum across multiple. Every session is tailored to your goals and current skill level.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
                    {topics.map((topic) => (
                        <div class={`glass-card group hover:-translate-y-1 transition-all duration-300 border ${topic.border} ${topic.bg}`}>
                            <div class={`text-xs font-mono tracking-widest uppercase mb-3 font-bold ${topic.color}`}>{topic.title}</div>
                            <p class="text-sm text-secondary leading-relaxed">{topic.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             HOW IT WORKS
        ════════════════════════════════════════════════════════ -->
        <section class="py-24 bg-[#080808] border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The Process</span>
                    <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-4">
                        How It <span class="text-gradient">Works</span>
                    </h2>
                </div>

                <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    {[
                        { step: '01', title: 'Book a Session', desc: 'Pick a time that works for you. Tell us what you want to learn and your current skill level. No prep required.' },
                        { step: '02', title: 'Custom Curriculum', desc: 'We prepare a hands-on session built entirely around your use case, your tools, and your goals. Zero generic slides.' },
                        { step: '03', title: 'Build Together', desc: 'Live 1-on-1 via video call. We build real things together. You leave with working knowledge and a recorded session to keep.' },
                    ].map((item) => (
                        <div class="glass-card text-center group hover:-translate-y-2 transition-all duration-300">
                            <div class="text-5xl font-extrabold text-accent/20 mb-4 group-hover:text-accent/40 transition-colors">{item.step}</div>
                            <h3 class="text-xl font-bold mb-3 text-white">{item.title}</h3>
                            <p class="text-secondary text-sm leading-relaxed">{item.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             WHO IT'S FOR
        ════════════════════════════════════════════════════════ -->
        <section class="py-24">
            <div class="container mx-auto px-4 text-center">
                <span class="text-accent font-mono text-xs tracking-widest uppercase">Audience</span>
                <h2 class="text-3xl md:text-4xl font-bold mt-4 mb-12">Who It's <span class="text-gradient">For</span></h2>
                <div class="flex flex-wrap justify-center gap-4 max-w-3xl mx-auto">
                    {['Founders & CEOs', 'Marketing Teams', 'Operations Managers', 'Developers', 'Freelancers', 'Agency Owners', 'Sales Teams', 'Content Creators'].map((audience) => (
                        <div class="px-6 py-3 rounded-full bg-surface/80 border border-white/10 text-sm font-medium text-white hover:border-accent/40 hover:bg-accent/5 transition-all">
                            {audience}
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             FAQ
        ════════════════════════════════════════════════════════ -->
        <section class="py-24 bg-[#080808] border-y border-white/5">
            <div class="container mx-auto px-4 max-w-3xl">
                <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center">Frequently Asked <span class="text-gradient">Questions</span></h2>
                <div class="space-y-4">
                    {faqs.map((faq) => (
                        <details class="glass-card cursor-pointer group">
                            <summary class="font-bold text-white list-none flex items-center justify-between">
                                {faq.question}
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-secondary group-open:rotate-180 transition-transform"><polyline points="6 9 12 15 18 9"/></svg>
                            </summary>
                            <p class="text-secondary mt-4 leading-relaxed">{faq.answer}</p>
                        </details>
                    ))}
                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════════
             CTA
        ════════════════════════════════════════════════════════ -->
        <section class="py-32 relative text-center overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(34,197,94,0.12)_0%,transparent_65%)]" />
            <div class="container mx-auto px-4 relative z-10 max-w-3xl">
                <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest uppercase text-green-400 border border-green-500/25 bg-green-500/5 rounded-full px-4 py-2 mb-10">
                    <span class="w-1.5 h-1.5 rounded-full bg-green-400 inline-block animate-pulse"></span>
                    Sessions Available Now
                </div>
                <h2 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tighter leading-tight">
                    Stop Watching Tutorials.<br />
                    <span class="text-gradient">Start Building.</span>
                </h2>
                <p class="text-xl text-secondary mb-12 leading-relaxed max-w-2xl mx-auto">
                    Learn from practitioners, not theorists. Book your first session and walk away with something working.
                </p>
                <div class="flex flex-wrap justify-center gap-4">
                    <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
                        Book a Training Session
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                    <a href="/pricing" class="inline-flex items-center gap-2 text-lg px-10 py-5 rounded-xl border border-white/15 text-secondary hover:text-white hover:border-white/30 transition-all">
                        View Pricing
                    </a>
                </div>
            </div>
        </section>

    </main>
    <Footer />
</Layout>
