---
import Layout from '../layouts/Layout.astro';
import ProductHero from '../components/ProductHero.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import ProductVideoPlayer from '../components/ProductVideoPlayer';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import assistantHero from '../assets/private_assistant_hero.png';
---

<Layout
    title="The Private Assistant | Done-For-You OpenClaw AI Setup | SystemPros.ai"
    description="A done-for-you OpenClaw personal AI assistant on WhatsApp, Telegram, Discord, Slack & more. 3,000+ skills, persistent memory, and a personality crafted just for you."
>
    <ServiceSchema name="The Private Assistant" description="Done-for-you OpenClaw personal AI assistant setup, configuration, skill installation, and training service." serviceType="AIConsulting" />
    <Breadcrumbs currentTitle="The Private Assistant" />

    <main class="overflow-x-hidden">

        <!-- Hero -->
        <ProductHero
            badge="Personal AI"
            title='Your Personal AI.<br /><span class="text-gradient">Everywhere You Are.</span>'
            subtitle="A done-for-you OpenClaw AI assistant on WhatsApp, Telegram, Discord, iMessage, Slack, and Teams. 3,000+ skills, persistent memory, and a personality crafted just for you."
            ctaText="Get Your Assistant"
            ctaLink="/contact"
            secondaryCtaText="View Pricing"
            secondaryCtaLink="/pricing"
            heroImage={assistantHero}
            heroImageAlt="Private AI assistant connected to messaging platforms"
        />

        <!-- What is OpenClaw -->
        <section class="py-24 bg-surface/30 border-y border-white/5">
            <div class="container mx-auto px-4">
                <div class="max-w-5xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
                    <div>
                        <span class="text-accent font-mono text-sm tracking-widest uppercase">Powered By</span>
                        <h2 class="text-3xl md:text-5xl font-bold mt-4 mb-8">What is <span class="text-gradient">OpenClaw?</span></h2>
                        <div class="space-y-4 text-secondary leading-relaxed">
                            <p>
                                OpenClaw is the world's fastest-growing open-source AI assistant — <strong class="text-white">247,000+ GitHub stars</strong> and counting. It's a personal AI that lives on the messaging platforms you already use.
                            </p>
                            <p>
                                Unlike ChatGPT or other web-based assistants, OpenClaw runs on <strong class="text-white">your device</strong>, keeps <strong class="text-white">your data private</strong>, and connects to <strong class="text-white">20+ messaging platforms</strong> so your AI is always one message away.
                            </p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        {[
                            { stat: '247K+', label: 'GitHub Stars', sub: 'Open Source' },
                            { stat: '3,000+', label: 'Community Skills', sub: 'Via ClawHub' },
                            { stat: '20+', label: 'Messaging Platforms', sub: 'WhatsApp, Slack, etc.' },
                            { stat: '24/7', label: 'Persistent Memory', sub: 'Never forgets context' },
                        ].map((item) => (
                            <div class="glass-card text-center p-6">
                                <div class="text-2xl font-extrabold text-accent mb-1">{item.stat}</div>
                                <div class="text-sm font-semibold text-white">{item.label}</div>
                                <div class="text-xs text-secondary mt-1">{item.sub}</div>
                            </div>
                        ))}
                    </div>
                </div>
            </div>
        </section>

        <!-- MOTION INFOGRAPHIC VIDEO -->
        <section class="py-20 bg-[#060606]">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The System Visualized</span>
                    <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-3">Your AI Assistant <span class="text-gradient">In Motion</span></h2>
                    <p class="text-secondary max-w-xl mx-auto">See how OpenClaw connects across 20+ platforms with 3,000+ skills — done for you from day one.</p>
                </div>
                <div class="max-w-md mx-auto rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-blue-500/10">
                    <ProductVideoPlayer id="private-assistant" client:visible />
                </div>
            </div>
        </section>

        <!-- Platform Icons Section -->
        <section class="py-20">
            <div class="container mx-auto px-4 text-center">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">One Assistant. <span class="text-gradient">Every Platform.</span></h2>
                <p class="text-secondary mb-12 max-w-xl mx-auto">Your AI lives wherever you chat. No switching apps. No copy-pasting. Just message it.</p>

                <div class="flex flex-wrap justify-center gap-6 max-w-3xl mx-auto">
                    {['WhatsApp', 'Telegram', 'Discord', 'Slack', 'Teams', 'iMessage', 'Signal', 'Email'].map((platform) => (
                        <div class="px-5 py-3 rounded-xl bg-surface/80 border border-white/10 text-sm font-medium text-white hover:border-accent/40 hover:bg-accent/5 transition-all">
                            {platform}
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- What We Do For You -->
        <section class="py-24 bg-[#080808]">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">The Done-For-You <span class="text-gradient">Package</span></h2>
                    <p class="text-secondary max-w-xl mx-auto">OpenClaw is free. Setting it up properly isn't simple. That's where we come in.</p>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
                    {[
                        { title: 'Install & Configure', desc: 'We install OpenClaw on your Mac, Windows, Linux, or remote server. Configured for optimal performance.' },
                        { title: 'Connect Your Channels', desc: 'We link your WhatsApp, Telegram, Discord, Slack, Teams, iMessage — whatever you use.' },
                        { title: 'Select & Install Skills', desc: 'We browse 3,000+ community skills on ClawHub and install the ones that match your workflow.' },
                        { title: 'Write Your SOUL.md', desc: 'We craft a custom personality file that defines how your AI communicates, thinks, and behaves.' },
                        { title: 'Train On Your Data', desc: 'We connect it to your Obsidian notes, files, and workflows. Your AI knows your world.' },
                        { title: 'Ongoing Support', desc: 'We provide support, skill updates, and optimization as OpenClaw evolves and your needs change.' },
                    ].map((item) => (
                        <div class="glass-card group hover:-translate-y-1 transition-all duration-300">
                            <h3 class="text-lg font-bold mb-3 text-white group-hover:text-accent transition-colors">{item.title}</h3>
                            <p class="text-sm text-secondary leading-relaxed">{item.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- Use Cases -->
        <section class="py-24">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">Built For <span class="text-gradient">Every Role</span></h2>
                </div>

                <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
                    {[
                        { title: 'Executive Assistant', desc: 'Scheduling, email triage, meeting prep, reminders, and research — all via a single message thread.', color: 'border-blue-500/20 hover:border-blue-500/50' },
                        { title: 'Content Creator', desc: 'Drafting posts, researching topics, scheduling content, and managing your editorial calendar.', color: 'border-purple-500/20 hover:border-purple-500/50' },
                        { title: 'Developer Copilot', desc: 'Code review summaries, documentation lookups, deployment status checks, and PR management.', color: 'border-green-500/20 hover:border-green-500/50' },
                        { title: 'Sales Intelligence', desc: 'CRM updates, lead research, follow-up reminders, and competitive intelligence — on demand.', color: 'border-orange-500/20 hover:border-orange-500/50' },
                    ].map((useCase) => (
                        <div class={`glass-card group transition-all duration-300 hover:-translate-y-1 ${useCase.color}`}>
                            <h3 class="text-xl font-bold mb-3 text-white group-hover:text-accent transition-colors">{useCase.title}</h3>
                            <p class="text-secondary leading-relaxed">{useCase.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-32 relative text-center overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>
            <div class="container mx-auto px-4 relative z-10 max-w-3xl">
                <h2 class="text-4xl md:text-6xl font-extrabold mb-8 tracking-tighter">Your AI. Your Rules.<br/><span class="text-gradient">Your Data.</span></h2>
                <p class="text-xl text-secondary mb-12 leading-relaxed">
                    Private, powerful, and always available. Let us build your perfect assistant.
                </p>
                <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
                    Get Your Private Assistant
                </a>
            </div>
        </section>

    </main>
    <Footer />
</Layout>
