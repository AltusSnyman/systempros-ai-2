---
import Layout from '../layouts/Layout.astro';
import ProductHero from '../components/ProductHero.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import ProductVideoPlayer from '../components/ProductVideoPlayer';
import LeadReactorTimeline from '../components/LeadReactorTimeline';
import Breadcrumbs from '../components/seo/Breadcrumbs.astro';
import leadReactorHero from '../assets/lead_reactor_hero.png';
---

<Layout
    title="The Lead Reactor | Meta Ads to Booked Appointments | SystemPros.ai"
    description="Stop lighting your ad budget on fire. The Lead Reactor turns Meta ad clicks into booked appointments via instant multi-channel AI outreach — Voice AI, WhatsApp, iMessage, SMS — in under 10 seconds."
>
    <ServiceSchema name="The Lead Reactor" description="Complete Meta ads to booked-appointment automation system. Multi-channel AI outreach via Voice AI, iMessage, WhatsApp, and SMS. Under 10-second response time." serviceType="MarketingAutomation" />
    <Breadcrumbs currentTitle="The Lead Reactor" />

    <main class="overflow-x-hidden">

        <!-- ── HERO ─────────────────────────────────────────────────────────────── -->
        <ProductHero
            badge="Paid Ads Automation"
            title='Stop Lighting Your Ad Budget<br /><span class="text-gradient">On Fire.</span>'
            subtitle="Most agencies stop at the 'Click.' We don't stop until there's a qualified meeting on your calendar. We build the ads, run the traffic, and deploy a multi-channel Lead Reactor that hunts down your leads across iMessage, WhatsApp, and Voice AI until they book."
            ctaText="Deploy The Lead Reactor"
            ctaLink="/contact"
            secondaryCtaText="See The Math / Pricing"
            secondaryCtaLink="/pricing"
            heroImage={leadReactorHero}
            heroImageAlt="Lead Reactor multi-channel automation system"
        />

        <!-- ── AGITATION: THE AD SPEND GRAVEYARD ────────────────────────────────── -->
        <section class="py-24 bg-[#080808] relative z-10">
            <div class="container mx-auto px-4">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">Your Leads Are Dying in the<br /><span class="text-gradient">"5-Minute Death Zone."</span></h2>
                    <p class="text-secondary max-w-2xl mx-auto text-lg">The brutal reality of manual follow-up and single-channel thinking.</p>
                </div>

                <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                    <div class="glass-card group relative overflow-hidden hover:-translate-y-2 transition-all duration-300 border-red-500/10">
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-red-500/0 via-red-500/60 to-red-500/0"></div>
                        <div class="relative z-10">
                            <div class="mb-5 p-3 rounded-xl bg-red-500/10 w-fit border border-red-500/20">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-red-400">The Speed Gap</h3>
                            <p class="text-sm text-secondary leading-relaxed">
                                If you don't contact a Meta lead in under 5 minutes, your conversion probability drops by <strong class="text-white">400%.</strong> Manual follow-up is a suicide mission for your ROI.
                            </p>
                        </div>
                    </div>

                    <div class="glass-card group relative overflow-hidden hover:-translate-y-2 transition-all duration-300 border-orange-500/10">
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-orange-500/0 via-orange-500/60 to-orange-500/0"></div>
                        <div class="relative z-10">
                            <div class="mb-5 p-3 rounded-xl bg-orange-500/10 w-fit border border-orange-500/20">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#F97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-orange-400">The Single-Channel Trap</h3>
                            <p class="text-sm text-secondary leading-relaxed">
                                If you only call, you're ignored. If you only email, you're spam. People live on <strong class="text-white">WhatsApp, iMessage, and SMS.</strong> If you aren't there, you don't exist.
                            </p>
                        </div>
                    </div>

                    <div class="glass-card group relative overflow-hidden hover:-translate-y-2 transition-all duration-300 border-purple-500/10">
                        <div class="absolute top-0 left-0 right-0 h-1 bg-gradient-to-r from-purple-500/0 via-purple-500/60 to-purple-500/0"></div>
                        <div class="relative z-10">
                            <div class="mb-5 p-3 rounded-xl bg-purple-500/10 w-fit border border-purple-500/20">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#A855F7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                            </div>
                            <h3 class="text-xl font-bold mb-3 text-purple-400">The Scalability Wall</h3>
                            <p class="text-sm text-secondary leading-relaxed">
                                Your team can't call 50 leads a day at 2:00 AM. <strong class="text-white">Our Reactor can.</strong> While you sleep, the system is pre-qualifying and booking — at any volume.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── VIDEO 1: DEATH ZONE (Centered) ────────────────────────────────────── -->
        <section class="py-20 bg-[#060606] border-t border-white/5">
            <div class="container mx-auto px-4 max-w-5xl">
                <div class="text-center mb-12">
                    <span class="text-red-400 font-mono text-xs tracking-widest uppercase">Speed to Lead — Visualized</span>
                    <h2 class="text-3xl md:text-4xl font-bold mt-3 mb-3">The 5-Minute <span class="text-gradient">Death Zone</span></h2>
                    <p class="text-secondary max-w-xl mx-auto">Why speed-to-lead is the only metric that matters — and exactly how the Lead Reactor wins.</p>
                </div>
                <div class="max-w-md mx-auto rounded-2xl overflow-hidden border border-white/10 shadow-2xl shadow-red-500/10">
                    <ProductVideoPlayer id="lead-reactor-speed" client:visible />
                </div>
            </div>
        </section>

        <!-- ── FULL-SERVICE ENGINE: SCROLL TIMELINE ──────────────────────────────── -->
        <section class="py-24 bg-[#080808] border-t border-white/5">
            <div class="container mx-auto px-4">
                <div class="text-center mb-20">
                    <span class="text-accent font-mono text-xs tracking-widest uppercase">The Full-Service Engine</span>
                    <h2 class="text-3xl md:text-5xl font-bold mt-3 mb-4">We Build. We Run. <span class="text-gradient">We Convert.</span></h2>
                    <p class="text-secondary max-w-2xl mx-auto text-lg">You aren't buying software. You're buying a finished result — <strong class="text-white">a calendar full of confirmed appointments.</strong></p>
                </div>
                <LeadReactorTimeline client:visible />
            </div>
        </section>

        <!-- ── CHAIN REACTION: 2-COLUMN ──────────────────────────────────────────── -->
        <section class="py-24 bg-[#060606] border-t border-white/5">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="text-center mb-20">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">The <span class="text-gradient">Chain Reaction</span></h2>
                    <p class="text-secondary max-w-2xl mx-auto text-lg">One ad click detonates 6 simultaneous outreach channels — all in under 10 seconds.</p>
                </div>

                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <!-- Left: video -->
                    <div class="relative group">
                        <div class="absolute inset-0 bg-accent/10 blur-[80px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <div class="relative rounded-2xl overflow-hidden border border-white/10 aspect-square bg-[#0A0A0A]">
                            <ProductVideoPlayer id="lead-reactor-channels" client:visible />
                        </div>
                    </div>

                    <!-- Right: channels list -->
                    <div class="space-y-6">
                        <div>
                            <span class="text-accent font-mono text-xs tracking-widest uppercase">Multi-Channel Dominance</span>
                            <h3 class="text-3xl font-bold mt-3 mb-4">6 Channels.<br /><span class="text-gradient">Simultaneously.</span></h3>
                            <p class="text-secondary leading-relaxed text-lg mb-8">
                                Because one channel is one chance to lose them. We hit every platform they're on — at the exact moment their intent is highest.
                            </p>
                        </div>

                        <div class="space-y-4">
                            {[
                                { channel: 'Voice AI', desc: 'An instant, human-sounding outbound call within 10 seconds of the form fill.', color: 'text-blue-400', bg: 'bg-blue-500/10 border-blue-500/20' },
                                { channel: 'iMessage & SMS', desc: 'Native Apple iMessage delivery for 98% open rates. No app required.', color: 'text-purple-400', bg: 'bg-purple-500/10 border-purple-500/20' },
                                { channel: 'WhatsApp Business', desc: 'Direct engagement on the world\'s most used messaging app.', color: 'text-green-400', bg: 'bg-green-500/10 border-green-500/20' },
                                { channel: 'Smart Nurture', desc: 'Automated email & text sequences that handle objections before the meeting.', color: 'text-yellow-400', bg: 'bg-yellow-500/10 border-yellow-500/20' },
                            ].map((item) => (
                                <div class={`flex items-start gap-4 p-4 rounded-xl border ${item.bg} group hover:scale-[1.01] transition-transform duration-200`}>
                                    <div class={`w-2 h-2 rounded-full mt-2 flex-shrink-0 ${item.color.replace('text-', 'bg-')}`}></div>
                                    <div>
                                        <div class={`font-bold text-sm mb-1 ${item.color}`}>{item.channel}</div>
                                        <div class="text-secondary text-sm leading-relaxed">{item.desc}</div>
                                    </div>
                                </div>
                            ))}
                        </div>

                        <div class="pt-2">
                            <div class="p-5 rounded-xl border border-accent/20 bg-accent/5">
                                <div class="text-accent font-bold text-sm uppercase tracking-wider mb-2">The End Goal</div>
                                <div class="text-white font-semibold">A <span class="text-accent">Booked Appointment</span> synced to your Google or Outlook calendar. You just show up.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── PROFIT GAP COMPARISON TABLE ──────────────────────────────────────── -->
        <section class="py-24 bg-[#080808] border-t border-white/5">
            <div class="container mx-auto px-4 max-w-4xl">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-bold mb-4">The <span class="text-gradient">"Profit Gap"</span> Comparison</h2>
                    <p class="text-secondary max-w-xl mx-auto">Most agencies give you a list of names. We give you a calendar full of confirmed appointments.</p>
                </div>

                <div class="rounded-2xl overflow-hidden border border-white/10">
                    <div class="grid grid-cols-2">
                        <div class="py-4 px-8 bg-red-900/20 border-b border-white/10 border-r border-white/10">
                            <span class="text-red-400 font-bold text-sm uppercase tracking-widest">The "DIY" Ad Hole</span>
                        </div>
                        <div class="py-4 px-8 bg-accent/10 border-b border-white/10">
                            <span class="text-accent font-bold text-sm uppercase tracking-widest">The Lead Reactor System</span>
                        </div>
                    </div>
                    {[
                        { label: 'Response Time', old: '"When we get to it"', new: 'Under 10 Seconds' },
                        { label: 'Outreach', old: 'One phone call (maybe)', new: '6 Channels Simultaneously' },
                        { label: 'Prequalification', old: 'Manual / None', new: 'Automated AI Screening' },
                        { label: 'Ad Creative', old: 'Generic stock templates', new: 'Engineered, tested creatives' },
                        { label: 'Result', old: '70% Lead Ghosting', new: '100% Contact Rate', highlight: true },
                    ].map((row, i) => (
                        <div class={`grid grid-cols-2 border-b border-white/5 last:border-b-0 ${i % 2 === 0 ? 'bg-white/[0.01]' : ''}`}>
                            <div class="py-5 px-8 border-r border-white/10">
                                <div class="text-xs text-secondary/60 uppercase tracking-wider mb-1">{row.label}</div>
                                <div class="text-sm text-red-300/80 flex items-center gap-2">
                                    <span class="text-red-500">✗</span> {row.old}
                                </div>
                            </div>
                            <div class="py-5 px-8">
                                <div class="text-xs text-secondary/60 uppercase tracking-wider mb-1">&nbsp;</div>
                                <div class={`text-sm flex items-center gap-2 ${row.highlight ? 'text-accent font-bold text-base' : 'text-white/80'}`}>
                                    <span class="text-accent">✓</span> {row.new}
                                </div>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- ── HIDDEN FACTORY: 2-COLUMN (Copy left, Video right) ─────────────────── -->
        <section class="py-24 bg-[#060606] border-t border-white/5">
            <div class="container mx-auto px-4 max-w-6xl">
                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <!-- Left: copy -->
                    <div class="space-y-6">
                        <span class="text-accent font-mono text-xs tracking-widest uppercase">Why It's Better</span>
                        <h2 class="text-3xl md:text-4xl font-bold mt-3">The Hidden Factory Logic.<br /><span class="text-gradient">Industrial Efficiency.</span></h2>
                        <p class="text-secondary leading-relaxed text-lg">
                            Your competitors are busy manually dialing numbers and leaving voicemails. You are running a <strong class="text-white">Hidden Factory</strong> that processes leads with industrial efficiency.
                        </p>
                        <p class="text-secondary leading-relaxed">
                            Every dollar you spend on ads is maximized because the Reactor never forgets to follow up, never gets tired, and never misses a speed-to-lead window. <strong class="text-white">It just runs.</strong>
                        </p>

                        <div class="grid grid-cols-2 gap-4 pt-2">
                            {[
                                { label: 'Contact Rate', value: '100%', sub: 'vs industry avg 30%' },
                                { label: 'Response Time', value: '< 10s', sub: 'vs industry avg 4hrs' },
                                { label: 'Channels', value: '6x', sub: 'simultaneous outreach' },
                                { label: 'Hours Active', value: '24/7', sub: 'including 2am and weekends' },
                            ].map((stat) => (
                                <div class="glass-card p-5 text-center">
                                    <div class="text-2xl font-extrabold text-accent mb-1">{stat.value}</div>
                                    <div class="text-white font-semibold text-sm mb-1">{stat.label}</div>
                                    <div class="text-secondary text-xs">{stat.sub}</div>
                                </div>
                            ))}
                        </div>
                    </div>

                    <!-- Right: video -->
                    <div class="relative group">
                        <div class="absolute inset-0 bg-accent/10 blur-[80px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <div class="relative rounded-2xl overflow-hidden border border-white/10 aspect-square bg-[#0A0A0A]">
                            <ProductVideoPlayer id="lead-reactor" client:visible />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ── FINAL CTA ──────────────────────────────────────────────────────────── -->
        <section class="py-32 relative text-center overflow-hidden">
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-blue-900/25 via-main to-main z-0"></div>
            <div class="container mx-auto px-4 relative z-10 max-w-3xl">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-8">
                    <span class="text-accent text-xs font-bold tracking-wider uppercase">Claim Your Territory</span>
                </div>
                <h2 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tighter">
                    Ready to turn your ad spend into an<br /><span class="text-gradient">Appointment Machine?</span>
                </h2>
                <p class="text-xl text-secondary mb-12 leading-relaxed max-w-2xl mx-auto">
                    We handle the creative, the ads, the tech, and the booking.<br /><strong class="text-white">You just show up to the meetings.</strong>
                </p>
                <a href="/contact" class="btn-cta inline-flex items-center gap-2 text-lg px-10 py-5">
                    Build My Lead Reactor
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                </a>
            </div>
        </section>

    </main>
    <Footer />
</Layout>
