        </div>
    </section>

    <!-- SECTION 8: FINAL CTA -->
    <section class="py-32 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-t from-purple-900/20 to-transparent"></div>
        <div class="absolute inset-0 bg-[url('/assets/grid.svg')] bg-center opacity-[0.03] pointer-events-none"></div>
        <div class="container mx-auto px-4 relative z-10 max-w-3xl">
            <h2 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tighter">
                Stop Losing Revenue <br/>to Empty Chairs.
            </h2>
            <p class="text-xl text-secondary mb-10 max-w-xl mx-auto">
                Get a free, no-obligation audit of your salon's growth potential. We'll show you exactly how many clients and dollars you're leaving on the table — and how to fix it.
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
                <a href="/contact" class="btn-primary text-xl px-12 py-6 bg-gradient-to-r from-purple-600 to-pink-500 hover:from-purple-500 hover:to-pink-400 shadow-[0_0_40px_rgba(168,85,247,0.4)]">
                    Book Your Free Salon Growth Audit
                </a>
            </div>
            <p class="text-sm text-secondary/50 mt-6">Takes 15 minutes. Zero commitment. Real numbers.</p>
        </div>
    </section>

    <Footer />
</Layout>

