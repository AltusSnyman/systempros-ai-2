---

<Layout
  title="AI Solutions by Industry | SystemPros.ai"
  description="All 6 AI systems — Voice AI, Lead Gen Websites, Lead Reactor, Private Assistant, Consultation, and Training — deployed for your industry. Roofing, Dental, Landscaping, Coaching and more."
>
  <main class="overflow-x-hidden">

    <!-- HERO -->
    <section class="relative pt-36 pb-16 overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_0%,rgba(59,130,246,0.13)_0%,transparent_55%)]" />
      <div class="container mx-auto px-4 relative z-10 text-center max-w-4xl">
        <div class="inline-flex items-center gap-2 text-xs font-mono tracking-widest uppercase text-accent border border-accent/25 bg-accent/5 rounded-full px-4 py-2 mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse inline-block"></span>
          Industry-Specific AI Deployment
        </div>
        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-tight mb-6">
          AI Built for<br /><span class="text-gradient">Your Industry.</span>
        </h1>
        <p class="text-xl text-secondary leading-relaxed max-w-2xl mx-auto mb-10">
          Every client receives all 6 of our AI systems — each one engineered to the specific workflows, pain points, and revenue drivers of your vertical.
        </p>
        <!-- 6 service pills -->
        <div class="flex flex-wrap items-center justify-center gap-2 mb-10">
          {[
            { name: 'Revenue Triad',    cls: 'text-blue-400 border-blue-500/25 bg-blue-500/10'   },
            { name: 'Lead Gen Sites',   cls: 'text-cyan-400 border-cyan-500/25 bg-cyan-500/10'   },
            { name: 'Lead Reactor',     cls: 'text-amber-400 border-amber-500/25 bg-amber-500/10' },
            { name: 'Private Asst.',    cls: 'text-purple-400 border-purple-500/25 bg-purple-500/10' },
            { name: 'Consultation',     cls: 'text-green-400 border-green-500/25 bg-green-500/10' },
            { name: 'Training',         cls: 'text-rose-400 border-rose-500/25 bg-rose-500/10'   },
          ].map(p => (
            <span class={`inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold border ${p.cls}`}>{p.name}</span>
          ))}
        </div>
        <a href="#industries" class="inline-flex items-center gap-2 text-secondary hover:text-white transition-colors text-sm font-semibold">
          Browse Industries
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
        </a>
      </div>
    </section>

    <!-- INDUSTRY SHOWCASES -->
    <section id="industries" class="py-8">
      <div class="container mx-auto px-4 space-y-8 max-w-7xl">

        {INDUSTRIES.map((ind, i) => {
          const isEven = i % 2 === 0;
          return (
            <div class="glass-card p-0 overflow-hidden hover:border-white/15 transition-all duration-300">
              <div class={`grid lg:grid-cols-2 ${isEven ? '' : 'lg:[&>*:first-child]:order-2'}`}>

                <!-- Video Column -->
                <div class="relative bg-[#050505] aspect-square lg:aspect-auto lg:min-h-[440px] flex items-center justify-center overflow-hidden">
                  <div class="absolute inset-0 bg-accent/5" />
                  <div class="w-full h-full">
                    <ProductVideoPlayer
                      id="industry-showcase"
                      inputProps={ind.videoProps}
                      client:visible
                    />
                  </div>
                </div>

                <!-- Content Column -->
                <div class="flex flex-col justify-center p-8 lg:p-12 space-y-6">
                  <!-- Badge + heading -->
                  <div>
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-2xl">{ind.emoji}</span>
                      <span class="text-xs font-bold tracking-widest uppercase text-secondary border border-white/10 rounded-full px-3 py-1">{ind.category}</span>
                    </div>
                    <h2 class="text-3xl md:text-4xl font-extrabold tracking-tighter text-white mb-2">{ind.name} AI</h2>
                    <p class="text-accent font-semibold text-lg">{ind.tagline}</p>
                  </div>

                  <!-- Bullets -->
                  <ul class="space-y-3">
                    {ind.bullets.map(bullet => (
                      <li class="flex items-start gap-3">
                        <span class="text-accent mt-0.5 shrink-0">
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </span>
                        <span class="text-secondary text-sm leading-relaxed">{bullet}</span>
                      </li>
                    ))}
                  </ul>

                  <!-- Buttons -->
                  <div class="flex flex-wrap gap-3 pt-2">
                    <a
                      href={ind.href}
                      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl btn-primary font-semibold text-sm"
                    >
                      View Full Solution
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                    </a>
                    {ind.videoSrc && (
                      <AudioDemoModal
                        videoSrc={ind.videoSrc}
                        industryName={ind.name}
                        client:visible
                      />
                    )}
                  </div>
                </div>

              </div>
            </div>
          );
        })}

      </div>
    </section>

    <!-- CUSTOM ARCHITECTURE -->
    <section id="custom" class="py-32 relative bg-[#050505] overflow-hidden mt-12">
      <div class="absolute inset-0 bg-[url('/assets/grid.svg')] bg-center opacity-10"></div>
      <div class="container mx-auto px-4 text-center relative z-10">
        <div class="max-w-4xl mx-auto mb-16">
          <h2 class="text-4xl md:text-5xl font-bold mb-6">
            Don't See Your Industry?<br/>
            <span class="text-accent">We Will Architect It For You.</span>
          </h2>
          <p class="text-xl text-secondary leading-relaxed">
            Our 30-year IT background means we can map any workflow, no matter how complex. We build a custom AI system for your niche — trained on your SOPs and integrated with your existing software.
          </p>
        </div>
        <div class="relative max-w-3xl mx-auto mb-16 group">
          <div class="absolute inset-0 bg-blue-500/20 blur-[80px] rounded-full group-hover:bg-blue-500/30 transition-colors duration-700"></div>
          <Image
            src={customBuild}
            alt="Custom Architecture Build"
            class="relative z-10 w-full rounded-xl shadow-2xl border border-white/10 hover:border-accent/50 transition-colors duration-500"
          />
        </div>
        <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5 shadow-[0_0_40px_rgba(59,130,246,0.4)] hover:shadow-[0_0_60px_rgba(59,130,246,0.6)]">
          Request Custom Architecture Build
        </a>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-24 relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(59,130,246,0.12)_0%,transparent_65%)]" />
      <div class="container mx-auto px-4 relative z-10 text-center max-w-3xl">
        <h2 class="text-3xl md:text-5xl font-bold mb-6 tracking-tighter">
          These aren't just solutions.<br/>
          <span class="text-gradient">They're fully deployed AI workforces.</span>
        </h2>
        <p class="text-xl text-secondary mb-10">Every system works together. Book a call and we'll show you what the full stack looks like for your industry.</p>
        <a href="/contact" class="btn-primary inline-flex items-center gap-2 text-lg px-10 py-5">
          Book Your Deployment Call
        </a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
