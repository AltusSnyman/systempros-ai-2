---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ROICalculator from '../../components/ROICalculator.jsx';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';
import AudioDemoModal from '../../components/AudioDemoModal';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';

const videoProps = {
  industryName: 'Chiropractic',
  emoji: '🦴',
  tagline: 'Automate intake, reduce no-shows, fill every slot.',
  problemValue: '31',
  problemLabel: 'calls missed during lunch and after hours',
  problemCost: '$56k lost',
  applications: [
    'Answers patient calls 24/7',
    'Reduces no-shows automatically',
    'Follows Facebook ad leads in <10s',
    'Practice ops AI for your CA',
    'Growth strategy & audit',
    'Team AI skills training',
  ],
  stats: [
    { value: '0',    label: 'Missed lunch-hour calls', color: '#22C55E' },
    { value: '60%',  label: 'Fewer no-shows',          color: '#3B82F6' },
    { value: '2.5×', label: 'New patient volume',      color: '#F59E0B' },
  ],
};
---

<Layout
  title="AI Systems for Chiropractors | Patient Intake & No-Show Reduction"
  description="Patients in pain don't leave voicemails. Full-stack AI for chiropractic clinics: Voice AI, Lead Gen, Lead Reactor, Private Assistant, Consultation & Training."
  showChatWidget={false}
>
  <ServiceSchema
    name="AI Patient Intake & No-Show Reduction for Chiropractic Clinics"
    description="Full-stack AI deployment for chiropractic clinics covering voice response, patient intake, automated follow-up, and practice operations."
    serviceType="Chiropractic Practice AI Automation"
  />
  <Breadcrumbs currentTitle="Chiropractic AI Solutions" />

  <!-- ============================================================
       SECTION 1 — HERO
  ============================================================ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-16 overflow-hidden bg-main">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>

    <div class="container mx-auto px-4 z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/5">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">🦴 Chiropractic AI Solutions</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05]">
          Patients In Pain<br/>
          Don't Leave<br/>
          <span class="text-gradient">Voicemails.</span>
        </h1>

        <p class="text-xl text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0">
          When someone's back goes out, they call the first clinic that answers. Your CA is already handling check-ins, billing, and insurance questions simultaneously. We deploy 6 AI systems so no patient slips through the cracks.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start flex-wrap">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg">
            Book Free Audit
          </a>
          <a href="#solutions" class="px-7 py-3 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-semibold flex items-center gap-2 text-white">
            See All 6 Systems
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
          <AudioDemoModal videoSrc="/assets/industry-videos/chiro.mp4" industryName="Chiropractic" client:visible />
        </div>
      </div>

      <!-- Right: Remotion Video -->
      <div class="relative">
        <div class="absolute inset-0 bg-blue-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="relative z-10">
          <ProductVideoPlayer id="industry-showcase" inputProps={videoProps} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — KNOWN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-surface/20 border-y border-white/5">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/30 bg-red-500/5 mb-4">
          <span class="text-red-400 text-xs font-bold tracking-wider uppercase">Known Pain Points</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">You Already Know These Are <span class="text-red-400">Costing You</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">⏰</div>
          <h3 class="text-lg font-bold text-white mb-2">The Lunch-Hour Gap</h3>
          <p class="text-secondary text-sm leading-relaxed">60% of new patient calls happen during lunch and after 5pm — exactly when your CA is on break or the clinic is closed. Every unanswered call is a patient in pain who just called your competitor.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">👩‍💼</div>
          <h3 class="text-lg font-bold text-white mb-2">The One-CA Bottleneck</h3>
          <p class="text-secondary text-sm leading-relaxed">Your chiropractic assistant can only do one thing at a time. When phones ring during a busy intake, something breaks — the call goes unanswered, the patient waits, or billing gets delayed.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📋</div>
          <h3 class="text-lg font-bold text-white mb-2">Insurance Qualification Drain</h3>
          <p class="text-secondary text-sm leading-relaxed">'Do you take my insurance?' calls take 10+ minutes each and consume your CA's most productive hours. AI answers these instantly — and qualifies the patient simultaneously.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — HIDDEN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-[#0a0a0a]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/5 mb-4">
          <span class="text-amber-400 text-xs font-bold tracking-wider uppercase">⚠ Hidden Revenue Leaks</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">What You Probably <span class="text-amber-400">Haven't Measured</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">These aren't obvious. But they're bleeding your revenue every week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">60%</div>
          <h3 class="text-base font-bold text-white mb-2">New Patient Calls Missed At Peak Hours</h3>
          <p class="text-secondary text-sm leading-relaxed">60% of new chiropractic patient inquiries come during lunch or after 5pm. The clinics capturing them aren't bigger — they just have AI answering when yours doesn't.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">$4,200/wk</div>
          <h3 class="text-base font-bold text-white mb-2">No-Shows Bleed Revenue Silently</h3>
          <p class="text-secondary text-sm leading-relaxed">The average chiropractic practice loses $3,500–$6,000 per week to no-shows and late cancellations. Without an automated reminder and reschedule system, you're paying that tax every week.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">5 min</div>
          <h3 class="text-base font-bold text-white mb-2">Facebook Leads Go Cold Instantly</h3>
          <p class="text-secondary text-sm leading-relaxed">Facebook ad leads for chiropractic services go cold in 5 minutes without a call. You're running ads but not capturing the window that converts them.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — CONSEQUENCES
  ============================================================ -->
  <section class="py-24 border-y border-white/5 bg-surface/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold">What Happens If <span class="text-red-400">Nothing Changes</span></h2>
        <p class="text-secondary mt-4 max-w-xl mx-auto">This isn't a warning. It's a pattern every chiropractic clinic without systems eventually hits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">📉</div>
          <h3 class="font-bold text-white mb-2">This Month</h3>
          <p class="text-secondary text-sm">Patients in acute pain call the clinic that answers. Without after-hours AI, you're handing new patients to the practice down the street — every single lunch hour.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-bold text-white mb-2">Next 12 Months</h3>
          <p class="text-secondary text-sm">No-show losses compound. Without an automated reminder and reschedule system, you lose 15-20% of booked appointments every week — all carrying your fixed clinic overhead.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🏳️</div>
          <h3 class="font-bold text-white mb-2">Year 3+</h3>
          <p class="text-secondary text-sm">Clinics with AI-managed intake, recall, and ad follow-up have a structural cost advantage. You're still hiring a second CA just to handle the call volume they manage automatically.</p>
        </div>
      </div>

      <div class="p-8 rounded-2xl bg-red-500/8 border border-red-500/20 text-center">
        <p class="text-secondary text-sm uppercase tracking-widest font-mono mb-2">Estimated Annual Cost of Inaction</p>
        <div class="text-5xl font-black text-red-400">$218,400+</div>
        <p class="text-secondary mt-2 text-sm">Based on 14 missed calls/week × average plan of care value ($900) over 52 weeks</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — 6-SERVICE SOLUTION STACK
  ============================================================ -->
  <section id="solutions" class="py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-4">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">The Full Stack</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">6 Systems. Built For <span class="text-gradient">Chiropractic.</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">Every SystemPros client gets all six. Each one engineered to the specific pain points of your practice.</p>
      </div>

      <div class="space-y-24">

        <!-- 1. Revenue Triad (Voice AI) — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="revenue-triad" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-500/15 text-blue-400 border border-blue-500/25">Revenue Triad — Voice AI</span>
            <h3 class="text-3xl font-bold text-white">Answer Every Patient Call. Including Lunch Break.</h3>
            <p class="text-secondary leading-relaxed">Your AI voice agent handles calls during lunch, after 5pm, and on weekends — qualifying patients, booking appointments, and delivering a professional experience when your CA simply can't be there.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Handles calls during lunch, after 5pm, and weekends — zero coverage gaps</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Qualifies new patients: insurance, injury type, urgency level, and availability</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Books directly into your scheduling system — confirmed appointments, not callbacks</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Reactivates lapsed patients with automated re-engagement outreach</li>
            </ul>
            <a href="/voice-ai" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold text-sm transition-colors">
              Explore Revenue Triad <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 2. Lead Gen Websites — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-cyan-500/15 text-cyan-400 border border-cyan-500/25">Lead Gen Websites</span>
            <h3 class="text-3xl font-bold text-white">A Clinic Website That Books New Patients While You Adjust</h3>
            <p class="text-secondary leading-relaxed">Your current site is a brochure. We build a patient acquisition machine — with 24/7 booking, insurance FAQ automation, and landing pages that convert urgently searching patients while you're mid-adjustment.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>New patient booking widget works 24/7 — no staff required</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'Accepting new patients near me' landing pages rank and convert urgently</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Insurance FAQ answered automatically — 'Do you take Blue Cross?' in seconds</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Intake forms completed before the first appointment to save front-desk time</li>
            </ul>
            <a href="/lead-gen-websites" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold text-sm transition-colors">
              Explore Lead Gen Websites <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="lead-gen-websites" client:visible />
          </div>
        </div>

        <!-- 3. Lead Reactor — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="lead-reactor-speed" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Lead Reactor</span>
            <h3 class="text-3xl font-bold text-white">Call Your Facebook Ad Leads Before They See Your Competitor's Ad</h3>
            <p class="text-secondary leading-relaxed">Facebook chiropractic leads go cold in under 5 minutes. Lead Reactor calls them in under 10 seconds of form submission — before they've even closed the tab and found another clinic.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Facebook chiropractic leads called in under 10 seconds of form submission</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Multi-channel follow-up via Voice, SMS, and WhatsApp simultaneously</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>No-show patients automatically rescheduled without CA involvement</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Drop-off patients reactivated with care-plan continuation outreach</li>
            </ul>
            <a href="/lead-reactor" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold text-sm transition-colors">
              Explore Lead Reactor <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 4. Private Assistant — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-purple-500/15 text-purple-400 border border-purple-500/25">Private Assistant</span>
            <h3 class="text-3xl font-bold text-white">Your CA Has An AI Co-Pilot For Every Question</h3>
            <p class="text-secondary leading-relaxed">A private AI that knows your clinic — patient records, insurance plans, schedules, and supplier contacts. Accessible instantly, answering the questions that currently interrupt your sessions.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Insurance verification and benefits lookups handled instantly</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Patient history and treatment notes pulled during any call</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Daily schedule summaries and no-show alerts delivered to your team automatically</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Supplier and equipment queries resolved without interrupting your sessions</li>
            </ul>
            <a href="/private-assistant" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold text-sm transition-colors">
              Explore Private Assistant <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="private-assistant" client:visible />
          </div>
        </div>

        <!-- 5. Consultation — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="consultation" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/25">Consultation</span>
            <h3 class="text-3xl font-bold text-white">A Clinic Growth Blueprint From Healthcare-Focused AI Strategists</h3>
            <p class="text-secondary leading-relaxed">Before we build, we audit. Our consultation identifies every gap in your intake, no-show, and recall workflow — then architects the exact AI stack for your patient volume and growth goals.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Audit of your current new patient acquisition and intake workflow</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>No-show pattern analysis and automated solution design</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom AI deployment roadmap for your clinic size and patient volume</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Integration design for your EHR and scheduling platform</li>
            </ul>
            <a href="/consulting" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-semibold text-sm transition-colors">
