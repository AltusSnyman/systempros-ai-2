---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ROICalculator from '../../components/ROICalculator.jsx';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';
import AudioDemoModal from '../../components/AudioDemoModal';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';

const videoProps = {
  industryName: 'Landscaping',
  emoji: '🌿',
  tagline: 'Book estimates while running crews in the field.',
  problemValue: '22',
  problemLabel: 'missed calls per spring week',
  problemCost: '$44k lost',
  applications: [
    'Answers calls while crew works',
    'Converts spring ads to bookings',
    'Captures seasonal enquiries 24/7',
    'Crew routing AI via WhatsApp',
    'Scalable ops roadmap',
    'AI tool training for team',
  ],
  stats: [
    { value: '0',    label: 'Missed spring calls',   color: '#22C55E' },
    { value: '24/7', label: 'Booking availability',  color: '#06B6D4' },
    { value: '2.8×', label: 'More estimates booked', color: '#F59E0B' },
  ],
};
---

<Layout
  title="AI Systems for Landscaping Companies | Lead Capture & Crew Management"
  description="Answer every call while your crew works. Full-stack AI for landscapers: Voice AI, Lead Gen, Lead Reactor, Private Assistant, Consultation & Training."
  showChatWidget={false}
>
  <ServiceSchema
    name="AI Lead Capture & Operations for Landscaping"
    description="Full-stack AI deployment for landscaping companies covering voice response, lead generation, automated follow-up, and field operations."
    serviceType="Landscaping AI Automation"
  />
  <Breadcrumbs currentTitle="Landscaping AI Solutions" />

  <!-- ============================================================
       SECTION 1 — HERO
  ============================================================ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-16 overflow-hidden bg-main">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-green-900/20 via-main to-main z-0"></div>

    <div class="container mx-auto px-4 z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-green-500/30 bg-green-500/5">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">🌿 Landscaping AI Solutions</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05]">
          Book Estimates While<br/>
          Your Crew Runs<br/>
          <span class="text-gradient">The Field</span>
        </h1>

        <p class="text-xl text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0">
          You can't hear the phone over a Zero-Turn at full throttle. We deploy 6 AI systems so every spring lead is captured, every estimate is sent, and your busiest season becomes your most profitable.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start flex-wrap">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg">
            Book Free Audit
          </a>
          <a href="#solutions" class="px-7 py-3 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-semibold flex items-center gap-2 text-white">
            See All 6 Systems
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
          <AudioDemoModal videoSrc="/assets/industry-videos/landscaping.mp4" industryName="Landscaping" client:visible />
        </div>
      </div>

      <!-- Right: Remotion Video -->
      <div class="relative">
        <div class="absolute inset-0 bg-green-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="relative z-10">
          <ProductVideoPlayer id="industry-showcase" inputProps={videoProps} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — KNOWN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-surface/20 border-y border-white/5">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/30 bg-red-500/5 mb-4">
          <span class="text-red-400 text-xs font-bold tracking-wider uppercase">Known Pain Points</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">You Already Know These Are <span class="text-red-400">Costing You</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">🔇</div>
          <h3 class="text-lg font-bold text-white mb-2">The Zero-Turn Paradox</h3>
          <p class="text-secondary text-sm leading-relaxed">You can't hear the phone over a backpack blower at 100dB. While the phone rings, that customer books the landscaper who answered.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">🌸</div>
          <h3 class="text-lg font-bold text-white mb-2">Spring Rush Overwhelm</h3>
          <p class="text-secondary text-sm leading-relaxed">Spring hits every operator at once. One person can't manage phones, crew logistics, and 40 estimate requests simultaneously.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📝</div>
          <h3 class="text-lg font-bold text-white mb-2">Same-Day Quote Window</h3>
          <p class="text-secondary text-sm leading-relaxed">Quotes not sent same day have a 60% drop-off rate. With jobs running until 6pm, there's no time to quote while the lead is still hot.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — HIDDEN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-[#0a0a0a]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/5 mb-4">
          <span class="text-amber-400 text-xs font-bold tracking-wider uppercase">⚠ Hidden Revenue Leaks</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">What You Probably <span class="text-amber-400">Haven't Measured</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">These aren't obvious. But they're bleeding your revenue every week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">70%</div>
          <h3 class="text-base font-bold text-white mb-2">Estimates Not Sent Same Day Go Cold</h3>
          <p class="text-secondary text-sm leading-relaxed">70% of landscaping leads book whoever responded first. If you follow up tomorrow, they've already signed with someone else.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">3 yrs</div>
          <h3 class="text-base font-bold text-white mb-2">One Lost Contract = Years of LTV Gone</h3>
          <p class="text-secondary text-sm leading-relaxed">A recurring maintenance contract lost from a single missed call costs 3+ years of compounding revenue, not just one job.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">Mon AM</div>
          <h3 class="text-base font-bold text-white mb-2">Peak Search Time = Your Busiest Commute</h3>
          <p class="text-secondary text-sm leading-relaxed">Google searches for landscaping peak Monday morning while you're already on the road heading to your first job.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — CONSEQUENCES
  ============================================================ -->
  <section class="py-24 border-y border-white/5 bg-surface/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold">What Happens If <span class="text-red-400">Nothing Changes</span></h2>
        <p class="text-secondary mt-4 max-w-xl mx-auto">This isn't a warning. It's a pattern every landscaping company without systems eventually hits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">📉</div>
          <h3 class="font-bold text-white mb-2">This Season</h3>
          <p class="text-secondary text-sm">Competitor captures spring rush leads while your team is running full crews with no capacity for phone response.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-bold text-white mb-2">Next 12 Months</h3>
          <p class="text-secondary text-sm">Without a retention system, recurring clients don't renew automatically. You reset to zero acquisition every spring.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🏳️</div>
          <h3 class="font-bold text-white mb-2">Year 3+</h3>
          <p class="text-secondary text-sm">Landscapers who built AI-managed recurring revenue portfolios have predictable cashflow — you're still hunting new clients every spring.</p>
        </div>
      </div>

      <div class="p-8 rounded-2xl bg-red-500/8 border border-red-500/20 text-center">
        <p class="text-secondary text-sm uppercase tracking-widest font-mono mb-2">Estimated Annual Cost of Inaction</p>
        <div class="text-5xl font-black text-red-400">$92,000+</div>
        <p class="text-secondary mt-2 text-sm">Based on 10 missed calls/week × $4,200 average annual contract value</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — 6-SERVICE SOLUTION STACK
  ============================================================ -->
  <section id="solutions" class="py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-4">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">The Full Stack</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">6 Systems. Built For <span class="text-gradient">Landscaping.</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">Every SystemPros client gets all six. Each one engineered to the specific pain points of your trade.</p>
      </div>

      <div class="space-y-24">

        <!-- 1. Revenue Triad (Voice AI) — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="revenue-triad" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-500/15 text-blue-400 border border-blue-500/25">Revenue Triad — Voice AI</span>
            <h3 class="text-3xl font-bold text-white">Answer Every Estimate Call. Even At Full Throttle.</h3>
            <p class="text-secondary leading-relaxed">Your AI voice agent handles every call while your crew is running at 100dB — qualifying jobs, booking estimate appointments, and reactivating past clients around the clock.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Handles calls while your crew runs at 100dB — never misses a spring inquiry</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Qualifies the job: one-time cleanup vs. recurring maintenance vs. hardscape quote</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Books estimate appointments into your calendar automatically</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Reactivates past clients with spring cleanup and fall leaf outreach</li>
            </ul>
            <a href="/voice-ai" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold text-sm transition-colors">
              Explore Revenue Triad <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 2. Lead Gen Websites — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-cyan-500/15 text-cyan-400 border border-cyan-500/25">Lead Gen Websites</span>
            <h3 class="text-3xl font-bold text-white">A Website That Books Estimates While You Mow</h3>
            <p class="text-secondary leading-relaxed">Your current site is a brochure. We build a lead machine — with AI chat, instant quote capture, and spring-season landing pages that turn Google traffic into booked estimates while you're in the field.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Spring-season landing pages built to rank for local landscaping searches</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Instant quote form captures contact + job type while you're in the field</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>AI chat widget answers "do you do cleanups?" questions after hours</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Google review requests sent automatically after job completion</li>
            </ul>
            <a href="/lead-gen-websites" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold text-sm transition-colors">
              Explore Lead Gen Websites <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="lead-gen-websites" client:visible />
          </div>
        </div>

        <!-- 3. Lead Reactor — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="lead-reactor-speed" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Lead Reactor</span>
            <h3 class="text-3xl font-bold text-white">Respond To Facebook Ad Leads Before The Mower Cools Down</h3>
            <p class="text-secondary leading-relaxed">Spring ad leads die in minutes. Lead Reactor calls your Facebook and Google ad leads in under 10 seconds — before 4 other landscapers even open the notification.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Facebook ad leads called in under 10 seconds — before 4 other landscapers respond</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Spring promotion leads followed up via Voice, SMS, and WhatsApp simultaneously</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Automated sequence continues follow-up until prospect books or opts out</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Filters budget shoppers from serious recurring-contract inquiries</li>
            </ul>
            <a href="/lead-reactor" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold text-sm transition-colors">
              Explore Lead Reactor <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 4. Private Assistant — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-purple-500/15 text-purple-400 border border-purple-500/25">Private Assistant</span>
            <h3 class="text-3xl font-bold text-white">Your Entire Operation. One WhatsApp Conversation.</h3>
            <p class="text-secondary leading-relaxed">A private AI that knows your business — crew schedules, client properties, supplier contacts, job notes. Accessible via WhatsApp. Answers your team's questions instantly so you can focus on the job.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Field crew gets daily schedules and job updates via WhatsApp</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Client notes and property details pulled instantly for any job</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Supplier and equipment queries answered without calling you</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>End-of-day job completion summaries sent to owner automatically</li>
            </ul>
            <a href="/private-assistant" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold text-sm transition-colors">
              Explore Private Assistant <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="private-assistant" client:visible />
          </div>
        </div>

        <!-- 5. Consultation — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="consultation" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/25">Consultation</span>
            <h3 class="text-3xl font-bold text-white">A Growth Roadmap Built For Your Landscaping Business</h3>
            <p class="text-secondary leading-relaxed">Before we build, we audit. Our consultation identifies every gap in your current lead and operations workflow — then designs the exact system stack for your crew size, service mix, and growth goals.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Audit of your current call and estimate conversion flow</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Seasonal demand analysis — where your revenue leaks each off-season</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom AI stack designed for your crew size and service mix</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Integration plan for Jobber, LMN, or your existing scheduling tools</li>
            </ul>
            <a href="/consulting" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-semibold text-sm transition-colors">
              Explore Consultation <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 6. Training — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-rose-500/15 text-rose-400 border border-rose-500/25">Training</span>
            <h3 class="text-3xl font-bold text-white">Train Your Crew To Work Faster With AI Tools</h3>
