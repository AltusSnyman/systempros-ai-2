---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ROICalculator from '../../components/ROICalculator.jsx';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';
import AudioDemoModal from '../../components/AudioDemoModal';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';

const videoProps = {
  industryName: 'Roofing',
  emoji: '🏠',
  tagline: 'Zero missed leads. Even during a storm.',
  problemValue: '37',
  problemLabel: 'storm calls missed per week',
  problemCost: '$74k lost',
  applications: [
    'Handles 1,000 storm calls 24/7',
    'Books estimates online instantly',
    'Follows Meta leads in <10s',
    'Field ops AI via WhatsApp',
    'Growth roadmap & audit',
    'Crew AI upskilling',
  ],
  stats: [
    { value: '0',   label: 'Missed storm calls',    color: '#22C55E' },
    { value: '<10s',label: 'Lead response time',    color: '#3B82F6' },
    { value: '3×',  label: 'More estimates booked', color: '#F59E0B' },
  ],
};
---

<Layout
  title="AI Systems for Roofing Contractors | Storm Response & Lead Automation"
  description="Handle 1,000+ storm calls instantly. Full-stack AI for roofers: Voice AI, Lead Gen, Lead Reactor, Private Assistant, Consultation & Training — all engineered for your vertical."
  showChatWidget={false}
>
  <ServiceSchema
    name="AI Storm Response & Lead Automation for Roofing"
    description="Full-stack AI deployment for roofing contractors covering voice response, lead generation, automated follow-up, and field operations."
    serviceType="Roofing AI Automation"
  />
  <Breadcrumbs currentTitle="Roofing AI Solutions" />

  <!-- ============================================================
       SECTION 1 — HERO
  ============================================================ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-16 overflow-hidden bg-main">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>

    <div class="container mx-auto px-4 z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/5">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">🏠 Roofing AI Solutions</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05]">
          Storm Season<br/>
          Doesn't Wait For<br/>
          <span class="text-gradient">Voicemail.</span>
        </h1>

        <p class="text-xl text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0">
          When hail hits, your phone rings 500 times and your crew is on every roof in town. We deploy 6 AI systems — so every lead is captured, every estimate is booked, and every season is your best yet.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start flex-wrap">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg">
            Book Free Audit
          </a>
          <a href="#solutions" class="px-7 py-3 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-semibold flex items-center gap-2 text-white">
            See All 6 Systems
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
          <AudioDemoModal videoSrc="/assets/industry-videos/roofing.mp4" industryName="Roofing" client:visible />
        </div>
      </div>

      <!-- Right: Remotion Video -->
      <div class="relative">
        <div class="absolute inset-0 bg-blue-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="relative z-10">
          <ProductVideoPlayer id="industry-showcase" inputProps={videoProps} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — KNOWN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-surface/20 border-y border-white/5">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/30 bg-red-500/5 mb-4">
          <span class="text-red-400 text-xs font-bold tracking-wider uppercase">Known Pain Points</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">You Already Know These Are <span class="text-red-400">Costing You</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">🪜</div>
          <h3 class="text-lg font-bold text-white mb-2">The Ladder Paradox</h3>
          <p class="text-secondary text-sm leading-relaxed">You can't safely answer the phone from 20 feet up. Every missed call during a storm goes straight to the next roofer on Google — and they close the job.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">⛈️</div>
          <h3 class="text-lg font-bold text-white mb-2">Storm Surge Overwhelm</h3>
          <p class="text-secondary text-sm leading-relaxed">500+ calls hit in 24 hours. Your team is already deployed on-site. No answering service knows roofing well enough to qualify damage or book inspections.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📋</div>
          <h3 class="text-lg font-bold text-white mb-2">Insurance Follow-Up Slips</h3>
          <p class="text-secondary text-sm leading-relaxed">Leads go cold in 48 hours. With 3 jobs running simultaneously, the insurance follow-up falls through the cracks — and that $22k job evaporates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — HIDDEN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-[#0a0a0a]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/5 mb-4">
          <span class="text-amber-400 text-xs font-bold tracking-wider uppercase">⚠ Hidden Revenue Leaks</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">What You Probably <span class="text-amber-400">Haven't Measured</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">These aren't obvious. But they're bleeding your revenue every week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">68%</div>
          <h3 class="text-base font-bold text-white mb-2">Storm Leads Go 3+ Places</h3>
          <p class="text-secondary text-sm leading-relaxed">68% of storm-affected homeowners contact 3 or more roofers within the first hour. Speed-to-call isn't a nice-to-have — it's the only thing that wins the contract.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">55%</div>
          <h3 class="text-base font-bold text-white mb-2">Inquiries Are After Hours</h3>
          <p class="text-secondary text-sm leading-relaxed">55% of all storm inquiry calls come after 5pm — when homeowners get home and see the damage. Your office is closed. The competitor's AI isn't.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">5 min</div>
          <h3 class="text-base font-bold text-white mb-2">Angi Leads Expire Fast</h3>
          <p class="text-secondary text-sm leading-relaxed">Shared leads from Angie/HomeAdvisor expire in under 5 minutes if no call is made. You're paying for leads you can't convert because you don't have a system to respond instantly.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — CONSEQUENCES
  ============================================================ -->
  <section class="py-24 border-y border-white/5 bg-surface/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold">What Happens If <span class="text-red-400">Nothing Changes</span></h2>
        <p class="text-secondary mt-4 max-w-xl mx-auto">This isn't a warning. It's a pattern every roofing company without systems eventually hits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">📉</div>
          <h3 class="font-bold text-white mb-2">This Storm Season</h3>
          <p class="text-secondary text-sm">Competitors with AI response capture the leads your team physically can't answer. You win the slow week — they win the storm season.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-bold text-white mb-2">Next 12 Months</h3>
          <p class="text-secondary text-sm">No follow-up system means your past clients get called by competitors. You're running full speed just to stay flat — zero compounding revenue from existing relationships.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🏳️</div>
          <h3 class="font-bold text-white mb-2">Year 3+</h3>
          <p class="text-secondary text-sm">The roofers who deployed AI systems now have a cost advantage you can't match manually. Recruiting, retaining, and competing on price becomes a losing battle.</p>
        </div>
      </div>

      <div class="p-8 rounded-2xl bg-red-500/8 border border-red-500/20 text-center">
        <p class="text-secondary text-sm uppercase tracking-widest font-mono mb-2">Estimated Annual Cost of Inaction</p>
        <div class="text-5xl font-black text-red-400">$330,000+</div>
        <p class="text-secondary mt-2 text-sm">Based on 15 missed storm calls/week × $22,000 average job value</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — 6-SERVICE SOLUTION STACK
  ============================================================ -->
  <section id="solutions" class="py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-4">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">The Full Stack</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">6 Systems. Built For <span class="text-gradient">Roofing.</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">Every SystemPros client gets all six. Each one engineered to the specific pain points of your trade.</p>
      </div>

      <div class="space-y-24">

        <!-- 1. Revenue Triad (Voice AI) — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="revenue-triad" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-500/15 text-blue-400 border border-blue-500/25">Revenue Triad — Voice AI</span>
            <h3 class="text-3xl font-bold text-white">Answer Every Storm Call. Automatically.</h3>
            <p class="text-secondary leading-relaxed">Your AI voice agent handles 1,000 concurrent calls — qualifying damage severity, booking inspections into AccuLynx, and delivering a flawless customer experience at 2am on a Sunday.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Handles 1,000+ concurrent storm calls with zero hold time</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Qualifies damage: active leak vs. cosmetic vs. insurance claim</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Books inspections directly into AccuLynx or JobNimbus</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Reactivates past clients with pre-winter inspection outreach</li>
            </ul>
            <a href="/voice-ai" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold text-sm transition-colors">
              Explore Revenue Triad <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 2. Lead Gen Websites — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-cyan-500/15 text-cyan-400 border border-cyan-500/25">Lead Gen Websites</span>
            <h3 class="text-3xl font-bold text-white">A Website That Converts Storm Traffic 24/7</h3>
            <p class="text-secondary leading-relaxed">Your current site is a brochure. We build a lead machine — with AI chat, instant quote capture, and storm-season landing pages that turn Google traffic into booked inspections while you sleep.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Storm-season landing pages built to rank and convert</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>AI chat widget captures leads when you can't answer</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Instant quote forms with damage-type qualification</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Google review automation increases local ranking</li>
            </ul>
            <a href="/lead-gen-websites" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold text-sm transition-colors">
              Explore Lead Gen Websites <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="lead-gen-websites" client:visible />
          </div>
        </div>

        <!-- 3. Lead Reactor — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="lead-reactor-speed" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Lead Reactor</span>
            <h3 class="text-3xl font-bold text-white">Beat 4 Other Roofers To Every Angi Lead</h3>
            <p class="text-secondary leading-relaxed">Shared leads die in minutes. Lead Reactor calls your Angi, HomeAdvisor, and Facebook ad leads in under 10 seconds — before the other 4 roofers even open the notification.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Calls Angi/HomeAdvisor leads in under 10 seconds</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Follows up via Voice, SMS, WhatsApp simultaneously</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Facebook ad leads called while still on the ad</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Automated follow-up sequence until prospect responds</li>
            </ul>
            <a href="/lead-reactor" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold text-sm transition-colors">
              Explore Lead Reactor <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 4. Private Assistant — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-purple-500/15 text-purple-400 border border-purple-500/25">Private Assistant</span>
            <h3 class="text-3xl font-bold text-white">Your Entire Operation. One AI Brain.</h3>
            <p class="text-secondary leading-relaxed">A private AI that knows your business — crew schedules, job statuses, supplier contacts, insurance processes. Accessible via WhatsApp. Answers your team's questions instantly so you can focus on the roof.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Field crew gets job updates and schedules via WhatsApp</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Insurance claim documentation generated automatically</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Supplier pricing lookups and material orders supported</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Client follow-up reminders sent without you thinking about it</li>
            </ul>
            <a href="/private-assistant" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold text-sm transition-colors">
              Explore Private Assistant <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="private-assistant" client:visible />
          </div>
        </div>

        <!-- 5. Consultation — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="consultation" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/25">Consultation</span>
            <h3 class="text-3xl font-bold text-white">A Blueprint For Your AI-Powered Operation</h3>
            <p class="text-secondary leading-relaxed">Before we build, we audit. Our consultation identifies every gap in your current lead and operations workflow — then architects the exact system stack for your size, market, and growth goals.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Forensic audit of your current call and lead flow</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Competitor gap analysis — where they're winning on speed</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom AI deployment roadmap for your roofing operation</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Integration plan for AccuLynx, JobNimbus, or your existing tools</li>
            </ul>
            <a href="/consulting" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-semibold text-sm transition-colors">
              Explore Consultation <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 6. Training — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
