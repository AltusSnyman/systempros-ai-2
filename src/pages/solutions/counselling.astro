---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ROICalculator from '../../components/ROICalculator.jsx';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';
import AudioDemoModal from '../../components/AudioDemoModal';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';

const videoProps = {
  industryName: 'Counselling',
  emoji: '🧠',
  tagline: 'HIPAA-compliant triage and after-hours intake.',
  problemValue: '28',
  problemLabel: 'after-hours calls missed per week',
  problemCost: '$134k LTV lost',
  applications: [
    'Compassionate after-hours intake',
    'Therapist match triage',
    'Follows up referrals in <10s',
    'Practice ops AI for admin',
    'Growth strategy & audit',
    'Team AI skills training',
  ],
  stats: [
    { value: '0',      label: 'After-hours calls missed', color: '#22C55E' },
    { value: 'HIPAA',  label: 'Compliant intake',         color: '#3B82F6' },
    { value: '3×',     label: 'Correct therapist match',  color: '#F59E0B' },
  ],
};
---

<Layout
  title="AI Systems for Counselling Practices | HIPAA-Compliant Intake & After-Hours"
  description="The moment of courage shouldn't hit voicemail. Full-stack AI for counsellors: HIPAA-compliant intake, after-hours response, and practice automation."
  showChatWidget={false}
>
  <ServiceSchema
    name="AI Intake & After-Hours Response for Counselling Practices"
    description="Full-stack AI deployment for counselling practices covering HIPAA-compliant intake, after-hours response, therapist matching, and practice operations."
    serviceType="Counselling Practice AI Automation"
  />
  <Breadcrumbs currentTitle="Counselling AI Solutions" />

  <!-- ============================================================
       SECTION 1 — HERO
  ============================================================ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-16 overflow-hidden bg-main">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main z-0"></div>

    <div class="container mx-auto px-4 z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/5">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">🧠 Counselling AI Solutions</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05]">
          The Moment Of<br/>
          Courage Shouldn't<br/>
          <span class="text-gradient">Hit Voicemail.</span>
        </h1>

        <p class="text-xl text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0">
          People reach out for help at 9pm on a Tuesday — not at 10am on a Wednesday when your front desk opens. That moment of resolve is fragile. We deploy 6 AI systems that answer with compassion, route to the right therapist, and protect every intake with HIPAA compliance — around the clock.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start flex-wrap">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg">
            Book Free Audit
          </a>
          <a href="#solutions" class="px-7 py-3 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-semibold flex items-center gap-2 text-white">
            See All 6 Systems
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
          <AudioDemoModal videoSrc="/assets/industry-videos/counseling.mp4" industryName="Counselling" client:visible />
        </div>
      </div>

      <!-- Right: Remotion Video -->
      <div class="relative">
        <div class="absolute inset-0 bg-blue-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="relative z-10">
          <ProductVideoPlayer id="industry-showcase" inputProps={videoProps} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — KNOWN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-surface/20 border-y border-white/5">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/30 bg-red-500/5 mb-4">
          <span class="text-red-400 text-xs font-bold tracking-wider uppercase">Known Pain Points</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">You Already Know These Are <span class="text-red-400">Costing You</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">🌙</div>
          <h3 class="text-lg font-bold text-white mb-2">After-Hours Courage Gap</h3>
          <p class="text-secondary text-sm leading-relaxed">70% of people in emotional distress reach out after business hours — when the resolve is highest and the courage is fresh. Your voicemail sends them a message that says their moment doesn't matter.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">🔀</div>
          <h3 class="text-lg font-bold text-white mb-2">Wrong Therapist Match</h3>
          <p class="text-secondary text-sm leading-relaxed">A mismatched therapist in session one has an 80% likelihood of the client not returning. Without intake triage, you're assigning on availability — not clinical fit — and losing clients before they've started.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📋</div>
          <h3 class="text-lg font-bold text-white mb-2">Inconsistent HIPAA Intake</h3>
          <p class="text-secondary text-sm leading-relaxed">Manual intake processes introduce compliance risk. Every staff member handles sensitive disclosures differently. One inconsistency is a liability — in a practice that handles mental health data, that risk is unacceptable.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — HIDDEN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-[#0a0a0a]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/5 mb-4">
          <span class="text-amber-400 text-xs font-bold tracking-wider uppercase">⚠ Hidden Revenue Leaks</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">What You Probably <span class="text-amber-400">Haven't Measured</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">These aren't obvious. But they're bleeding your practice every week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">70%</div>
          <h3 class="text-base font-bold text-white mb-2">Crisis Callers Don't Call Back</h3>
          <p class="text-secondary text-sm leading-relaxed">70% of people who reach a voicemail in a moment of emotional distress don't call again. That's not a missed booking — that's a person who needed help and didn't get it, and a practice that can't measure what it's losing.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">80%</div>
          <h3 class="text-base font-bold text-white mb-2">Wrong Match = Client Gone After Session One</h3>
          <p class="text-secondary text-sm leading-relaxed">Assigning a client to the wrong therapist because you're matching on availability rather than clinical speciality loses that client within 2 sessions. And they rarely tell you why they left.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">12–18%</div>
          <h3 class="text-base font-bold text-white mb-2">Billing Errors From Manual Intake</h3>
          <p class="text-secondary text-sm leading-relaxed">Practices running manual intake processes lose 12–18% of revenue to billing errors, insurance verification gaps, and coding inconsistencies. AI-standardised intake eliminates this entirely.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — CONSEQUENCES
  ============================================================ -->
  <section class="py-24 border-y border-white/5 bg-surface/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold">What Happens If <span class="text-red-400">Nothing Changes</span></h2>
        <p class="text-secondary mt-4 max-w-xl mx-auto">This isn't a warning. It's a pattern every counselling practice without systems eventually hits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">📉</div>
          <h3 class="font-bold text-white mb-2">Tonight</h3>
          <p class="text-secondary text-sm">Someone reaches out at 9pm in their most vulnerable moment. Your voicemail tells them to call back tomorrow. 70% of them won't. That person doesn't get help, and your practice doesn't grow.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-bold text-white mb-2">Next 12 Months</h3>
          <p class="text-secondary text-sm">Without a correct-match intake system, client attrition stays high. You're spending marketing budget acquiring clients who leave after 2 sessions because the fit wasn't right.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🏳️</div>
          <h3 class="font-bold text-white mb-2">Year 3+</h3>
          <p class="text-secondary text-sm">Practices with AI-managed after-hours intake and therapist matching have lower attrition, higher lifetime client value, and better clinical outcomes. It's not just a business advantage — it's a better service.</p>
        </div>
      </div>

      <div class="p-8 rounded-2xl bg-red-500/8 border border-red-500/20 text-center">
        <p class="text-secondary text-sm uppercase tracking-widest font-mono mb-2">Estimated Annual Cost of Inaction</p>
        <div class="text-5xl font-black text-red-400">$134,400+</div>
        <p class="text-secondary mt-2 text-sm">Based on 8 after-hours missed calls/week × $4,800 average client lifetime value over 52 weeks</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — 6-SERVICE SOLUTION STACK
  ============================================================ -->
  <section id="solutions" class="py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-4">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">The Full Stack</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">6 Systems. Built For <span class="text-gradient">Counselling.</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">Every SystemPros client gets all six. Each one engineered to the specific needs of your practice.</p>
      </div>

      <div class="space-y-24">

        <!-- 1. Revenue Triad — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="revenue-triad" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-500/15 text-blue-400 border border-blue-500/25">Revenue Triad — Voice AI</span>
            <h3 class="text-3xl font-bold text-white">Compassionate After-Hours Intake. Every Time Someone Calls.</h3>
            <p class="text-secondary leading-relaxed">Your AI voice agent answers after-hours calls with calm, trained compassion — conducting intake triage, routing to the right therapist, and booking appointments overnight so no one falls through the cracks.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Answers after-hours calls with a calm, trained AI voice — not a voicemail prompt</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Conducts intake triage: presenting concern, urgency level, and therapy modality preference</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Routes to on-call therapist for crisis escalation — compliant with duty-of-care protocols</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Books initial appointments into your scheduling system overnight</li>
            </ul>
            <a href="/voice-ai" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold text-sm transition-colors">
              Explore Revenue Triad <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 2. Lead Gen Websites — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-cyan-500/15 text-cyan-400 border border-cyan-500/25">Lead Gen Websites</span>
            <h3 class="text-3xl font-bold text-white">A Practice Website That Converts Visitors At Their Most Vulnerable Moment</h3>
            <p class="text-secondary leading-relaxed">Your website needs to work when you don't. We build HIPAA-compliant intake flows, modality-specific landing pages, and after-hours booking widgets that capture clients when they're ready to commit.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>After-hours booking widget captures new clients when they're ready to commit</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Landing pages for specific modalities: anxiety, trauma, couples, LGBTQ+ affirming</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>AI chat handles 'do you offer sliding scale?' and intake FAQ without staff</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>HIPAA-compliant form collection and data handling built into the site architecture</li>
            </ul>
            <a href="/lead-gen-websites" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold text-sm transition-colors">
              Explore Lead Gen Websites <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="lead-gen-websites" client:visible />
          </div>
        </div>

        <!-- 3. Lead Reactor — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="lead-reactor-speed" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Lead Reactor</span>
            <h3 class="text-3xl font-bold text-white">Follow Up Every Referral Before The Moment of Motivation Fades</h3>
            <p class="text-secondary leading-relaxed">Psychology Today, Zocdoc, and direct referrals followed up in under 10 seconds — warm, professional, and compliant. No-shows rescheduled automatically. Lapsed clients reached with care-continuation outreach.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Psychology Today, Zocdoc, and direct referrals followed up in under 10 seconds</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Multi-channel outreach: Voice, SMS, and email — warm, professional, and compliant</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Client no-shows automatically offered reschedule options without admin involvement</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Lapsed clients receive care-continuation outreach to reduce dropout</li>
            </ul>
            <a href="/lead-reactor" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold text-sm transition-colors">
              Explore Lead Reactor <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 4. Private Assistant — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-purple-500/15 text-purple-400 border border-purple-500/25">Private Assistant</span>
            <h3 class="text-3xl font-bold text-white">Your Administrative Burden. Handled.</h3>
            <p class="text-secondary leading-relaxed">A private AI that handles insurance verification, session documentation support, billing queries, and scheduling coordination — so your therapists spend their time with clients, not paperwork.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Insurance verification and benefits lookups handled before intake appointments</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Session notes templates and documentation support for practitioners</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Billing queries and insurance coding questions answered instantly for admin staff</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Scheduling coordination across multiple therapists managed via AI</li>
            </ul>
            <a href="/private-assistant" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold text-sm transition-colors">
              Explore Private Assistant <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="private-assistant" client:visible />
          </div>
        </div>

        <!-- 5. Consultation — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="consultation" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/25">Consultation</span>
            <h3 class="text-3xl font-bold text-white">A Practice Growth Strategy That Doesn't Compromise Clinical Values</h3>
            <p class="text-secondary leading-relaxed">Before we build, we audit. Our consultation maps your intake workflow, therapist match process, and attrition points — then designs the AI stack that fills your books without compromising care quality.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Audit of your intake workflow, therapist match process, and attrition points</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>After-hours coverage gap analysis and AI solution architecture</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom deployment roadmap for your practice size and therapeutic specialities</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Integration design for SimplePractice, Theranest, or Jane</li>
            </ul>
            <a href="/consulting" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-semibold text-sm transition-colors">
