---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import ROICalculator from '../../components/ROICalculator.jsx';
import ProductVideoPlayer from '../../components/ProductVideoPlayer';
import AudioDemoModal from '../../components/AudioDemoModal';
import ServiceSchema from '../../components/seo/ServiceSchema.astro';
import Breadcrumbs from '../../components/seo/Breadcrumbs.astro';

const videoProps = {
  industryName: 'Coaching',
  emoji: '🎯',
  tagline: 'Book discovery calls and nurture leads on autopilot.',
  problemValue: '12',
  problemLabel: 'qualified leads lost to slow follow-up each week',
  problemCost: '$60k lost',
  applications: [
    'Qualifies and books discovery calls',
    'Follows up leads on every channel',
    'Nurtures webinar no-shows',
    'Business ops AI for coaches',
    'Funnel strategy & audit',
    'AI skills training for coaches',
  ],
  stats: [
    { value: '0',    label: 'Qualified leads lost',   color: '#22C55E' },
    { value: '7×',   label: 'Follow-up touchpoints',  color: '#06B6D4' },
    { value: '2.4×', label: 'Enrollment conversion',  color: '#F59E0B' },
  ],
};
---

<Layout
  title="AI Systems for Coaches | Discovery Call Booking & Lead Nurture Automation"
  description="Stop wasting discovery calls on tire-kickers. Full-stack AI for coaches: Voice AI, Lead Gen, Lead Reactor, Private Assistant, Consultation & Training."
  showChatWidget={false}
>
  <ServiceSchema
    name="AI Lead Qualification & Enrollment Automation for Coaches"
    description="Full-stack AI deployment for coaching businesses covering discovery call qualification, lead nurture, funnel automation, and business operations."
    serviceType="Coaching Business AI Automation"
  />
  <Breadcrumbs currentTitle="Coaching AI Solutions" />

  <!-- ============================================================
       SECTION 1 — HERO
  ============================================================ -->
  <section class="relative min-h-screen flex items-center pt-28 pb-16 overflow-hidden bg-main">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan-900/20 via-main to-main z-0"></div>

    <div class="container mx-auto px-4 z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Copy -->
      <div class="space-y-7 text-center lg:text-left">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-cyan-500/30 bg-cyan-500/5">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">🎯 Coaching AI Solutions</span>
        </div>

        <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.05]">
          Your Calendar Is<br/>
          For Clients. Not<br/>
          <span class="text-gradient">Tire-Kickers.</span>
        </h1>

        <p class="text-xl text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0">
          You built a coaching business to transform people — not to spend 4 hours a day qualifying leads, chasing no-shows, and following up with people who say 'I need to think about it'. We deploy 6 AI systems so your calendar fills with qualified buyers while you focus on delivery.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start flex-wrap">
          <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg">
            Book Free Audit
          </a>
          <a href="#solutions" class="px-7 py-3 rounded-xl border border-white/15 hover:bg-white/5 transition-all font-semibold flex items-center gap-2 text-white">
            See All 6 Systems
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Remotion Video -->
      <div class="relative">
        <div class="absolute inset-0 bg-cyan-500/10 blur-[80px] rounded-full pointer-events-none"></div>
        <div class="relative z-10">
          <ProductVideoPlayer id="industry-showcase" inputProps={videoProps} client:visible />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 2 — KNOWN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-surface/20 border-y border-white/5">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-red-500/30 bg-red-500/5 mb-4">
          <span class="text-red-400 text-xs font-bold tracking-wider uppercase">Known Pain Points</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">You Already Know These Are <span class="text-red-400">Costing You</span></h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📞</div>
          <h3 class="text-lg font-bold text-white mb-2">The Discovery Call Trap</h3>
          <p class="text-secondary text-sm leading-relaxed">Most coaches spend 20–30% of their working week on discovery calls with people who have no budget, no urgency, and no decision authority. Every unqualified call is time you could have spent delivering to paying clients.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">📣</div>
          <h3 class="text-lg font-bold text-white mb-2">Manual DM Outreach Burnout</h3>
          <p class="text-secondary text-sm leading-relaxed">Chasing leads through Instagram DMs, email, and follow-up calls takes 3–4 hours a day. That's delivery time you're trading for admin work — and it still doesn't scale.</p>
        </div>
        <div class="glass-card border-red-500/20 hover:border-red-500/40 transition-colors">
          <div class="text-3xl mb-4">⏳</div>
          <h3 class="text-lg font-bold text-white mb-2">The Launch-to-Enrollment Gap</h3>
          <p class="text-secondary text-sm leading-relaxed">Most coaches lose 60–90 days between launching a program and getting their first payment. Without an automated funnel follow-up system, momentum dies and the launch resets to zero.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 3 — HIDDEN PROBLEMS
  ============================================================ -->
  <section class="py-24 bg-[#0a0a0a]">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-14">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-amber-500/30 bg-amber-500/5 mb-4">
          <span class="text-amber-400 text-xs font-bold tracking-wider uppercase">⚠ Hidden Revenue Leaks</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">What You Probably <span class="text-amber-400">Haven't Measured</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">These aren't obvious. But they're bleeding your revenue every week.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">80%</div>
          <h3 class="text-base font-bold text-white mb-2">Sales Happen On Follow-Up 3–7, Not Call 1</h3>
          <p class="text-secondary text-sm leading-relaxed">60–80% of coaching program sales close on follow-up touchpoints 3 through 7. Most coaches stop at one or two. The revenue isn't lost — it's just not being chased.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">70%</div>
          <h3 class="text-base font-bold text-white mb-2">Masterclass No-Shows Don't Come Back</h3>
          <p class="text-secondary text-sm leading-relaxed">70% of masterclass registrants don't attend live. Without an automated replay sequence and follow-up, you pitched your best content to an empty room and got nothing for it.</p>
        </div>
        <div class="p-6 rounded-2xl border border-amber-500/15 bg-amber-500/5">
          <div class="text-4xl font-black text-amber-400 mb-2">40%</div>
          <h3 class="text-base font-bold text-white mb-2">Objections Are Costing You Closable Revenue</h3>
          <p class="text-secondary text-sm leading-relaxed">"I need to think about it" objections go unhandled in most coaching funnels. AI follow-up with objection-specific sequences converts 40% of stalled leads that would otherwise go cold.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 4 — CONSEQUENCES
  ============================================================ -->
  <section class="py-24 border-y border-white/5 bg-surface/10">
    <div class="container mx-auto px-4 max-w-5xl">
      <div class="text-center mb-14">
        <h2 class="text-3xl md:text-5xl font-bold">What Happens If <span class="text-red-400">Nothing Changes</span></h2>
        <p class="text-secondary mt-4 max-w-xl mx-auto">This isn't a warning. It's a pattern every coaching business without systems eventually hits.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">📉</div>
          <h3 class="font-bold text-white mb-2">This Launch</h3>
          <p class="text-secondary text-sm">Unqualified discovery calls drain your energy and fill your calendar with people who never buy. Meanwhile, the qualified leads who said "I'll think about it" book with someone who followed up.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🔄</div>
          <h3 class="font-bold text-white mb-2">Next 12 Months</h3>
          <p class="text-secondary text-sm">Without a systematic follow-up sequence, every launch resets. You're starting from zero acquisition every 8–12 weeks instead of building a compounding enrolled client base.</p>
        </div>
        <div class="p-6 rounded-2xl border border-white/8 bg-surface/30 text-center">
          <div class="text-2xl mb-3">🏳️</div>
          <h3 class="font-bold text-white mb-2">Year 3+</h3>
          <p class="text-secondary text-sm">Coaches with AI-managed funnels, follow-up, and qualifying have predictable enrollment — not feast-or-famine launches. The gap between you and them compounds every launch.</p>
        </div>
      </div>

      <div class="p-8 rounded-2xl bg-red-500/8 border border-red-500/20 text-center">
        <p class="text-secondary text-sm uppercase tracking-widest font-mono mb-2">Estimated Annual Cost of Inaction</p>
        <div class="text-5xl font-black text-red-400">$312,000+</div>
        <p class="text-secondary mt-2 text-sm">Based on 12 unqualified/missed leads per week × $5,000 average program × 52% conversion rate improvement</p>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SECTION 5 — 6-SERVICE SOLUTION STACK
  ============================================================ -->
  <section id="solutions" class="py-24">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-20">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-accent/30 bg-accent/5 mb-4">
          <span class="text-accent text-xs font-bold tracking-wider uppercase">The Full Stack</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-bold">6 Systems. Built For <span class="text-gradient">Coaching.</span></h2>
        <p class="text-secondary mt-4 max-w-2xl mx-auto">Every SystemPros client gets all six. Each one engineered to the specific pain points of your business.</p>
      </div>

      <div class="space-y-24">

        <!-- 1. Revenue Triad — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="revenue-triad" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-500/15 text-blue-400 border border-blue-500/25">Revenue Triad — Voice AI</span>
            <h3 class="text-3xl font-bold text-white">Only Talk To People Who Are Ready To Buy</h3>
            <p class="text-secondary leading-relaxed">Your AI voice agent pre-qualifies every discovery call applicant before they reach your calendar — screening for budget, urgency, and program fit so every call is a genuine sales conversation.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>AI pre-qualifies all discovery call applicants — budget, urgency, and fit screened first</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Unqualified leads routed to nurture sequences instead of your calendar</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Missed calls and voicemails followed up automatically — no lead left without a touchpoint</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-blue-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Past clients reactivated with upgrade program outreach automatically</li>
            </ul>
            <a href="/voice-ai" class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 font-semibold text-sm transition-colors">
              Explore Revenue Triad <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 2. Lead Gen Websites — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-cyan-500/15 text-cyan-400 border border-cyan-500/25">Lead Gen Websites</span>
            <h3 class="text-3xl font-bold text-white">A Funnel That Converts Traffic To Discovery Calls Automatically</h3>
            <p class="text-secondary leading-relaxed">Your current website is a brochure. We build a conversion machine — with AI-qualified booking pages, masterclass registration flows, and social proof architecture that turns traffic into booked calls around the clock.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>High-converting VSL and application pages built to filter qualified buyers</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>AI chat qualifies website visitors before they reach your booking page</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Masterclass registration pages with automated replay and follow-up sequences</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-cyan-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Testimonial and case study pages built for maximum social proof conversion</li>
            </ul>
            <a href="/lead-gen-websites" class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 font-semibold text-sm transition-colors">
              Explore Lead Gen Websites <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="lead-gen-websites" client:visible />
          </div>
        </div>

        <!-- 3. Lead Reactor — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="lead-reactor-speed" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-amber-500/15 text-amber-400 border border-amber-500/25">Lead Reactor</span>
            <h3 class="text-3xl font-bold text-white">Follow Up Every Lead Until They Say Yes Or No</h3>
            <p class="text-secondary leading-relaxed">New inquiries, masterclass no-shows, and stalled "I need to think about it" leads all get automated multi-channel follow-up — 7+ touchpoints across Voice, SMS, and email without you lifting a finger.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>New lead inquiries followed up within 10 seconds via Voice, SMS, and email</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Masterclass no-shows receive automated replay + follow-up sequence</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>'I need to think about it' leads enter AI objection-handling sequences</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-amber-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Multi-channel follow-up continues for 7+ touchpoints without you lifting a finger</li>
            </ul>
            <a href="/lead-reactor" class="inline-flex items-center gap-2 text-amber-400 hover:text-amber-300 font-semibold text-sm transition-colors">
              Explore Lead Reactor <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <!-- 4. Private Assistant — copy left, video right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="order-2 lg:order-1 space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-purple-500/15 text-purple-400 border border-purple-500/25">Private Assistant</span>
            <h3 class="text-3xl font-bold text-white">Run Your Entire Coaching Business From One AI Interface</h3>
            <p class="text-secondary leading-relaxed">A private AI that knows your business — client onboarding, program curriculum, content scheduling, and revenue tracking. Accessible on demand. Answers your admin questions instantly so you can focus on coaching.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Client onboarding documents, contracts, and resources sent automatically</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Program curriculum questions answered by AI so you're not the bottleneck</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Content scheduling, social drafts, and email sequences generated on request</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-purple-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Revenue tracking, enrollment stats, and launch performance summaries delivered daily</li>
            </ul>
            <a href="/private-assistant" class="inline-flex items-center gap-2 text-purple-400 hover:text-purple-300 font-semibold text-sm transition-colors">
              Explore Private Assistant <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
          <div class="order-1 lg:order-2">
            <ProductVideoPlayer id="private-assistant" client:visible />
          </div>
        </div>

        <!-- 5. Consultation — video left, copy right -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div>
            <ProductVideoPlayer id="consultation" client:visible />
          </div>
          <div class="space-y-5">
            <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-500/15 text-green-400 border border-green-500/25">Consultation</span>
            <h3 class="text-3xl font-bold text-white">A Funnel Architecture That Actually Converts Your Audience</h3>
            <p class="text-secondary leading-relaxed">Before we build, we audit. Our consultation identifies every gap from lead magnet to enrollment — then architects the exact AI system stack for your program price, audience, and launch model.</p>
            <ul class="space-y-2 text-sm text-secondary">
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Audit of your current funnel from lead magnet to enrollment</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Conversion gap analysis — where qualified buyers are dropping out of your pipeline</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Custom AI stack designed for your program price, audience, and launch model</li>
              <li class="flex items-start gap-2"><svg class="w-4 h-4 text-green-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>Offer positioning review to ensure your messaging attracts buyers, not browsers</li>
            </ul>
            <a href="/consulting" class="inline-flex items-center gap-2 text-green-400 hover:text-green-300 font-semibold text-sm transition-colors">
