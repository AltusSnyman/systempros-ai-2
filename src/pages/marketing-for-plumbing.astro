            <div class="flex flex-col sm:flex-row gap-6 justify-center items-center">
                <a href="/contact" class="btn-primary text-xl px-12 py-6 bg-gradient-to-r from-cyan-600 to-blue-500 hover:from-cyan-500 hover:to-blue-400 shadow-[0_0_40px_rgba(6,182,212,0.4)]">
