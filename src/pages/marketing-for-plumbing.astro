    <!-- SECTION 8: FINAL CTA -->
    <section class="py-32 text-center relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-t from-cyan-900/20 to-transparent"></div>
        <div class="absolute inset-0 bg-[url('/assets/grid.svg')] bg-center opacity-[0.03] pointer-events-none"></div>
        <div class="container mx-auto px-4 relative z-10 max-w-3xl">
