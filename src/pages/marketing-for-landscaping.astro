---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import ServiceSchema from '../components/seo/ServiceSchema.astro';
import FAQSchema from '../components/seo/FAQSchema.astro';

const faqs = [
    {
        question: "How does AI marketing work for landscaping companies?",
        answer: "We combine AI-powered voice agents with targeted Meta and Google advertising. The AI answers every call 24/7 — even when your crew is on site — books estimates instantly, and follows up with leads who didn't convert. Our ad campaigns keep a steady pipeline of residential and commercial jobs flowing in all year round."
    },
    {
        question: "How quickly will I see new leads coming in?",
        answer: "Most landscaping companies see their first ad-generated enquiries within the first week. The AI receptionist is live within 48 hours of onboarding. Reactivation campaigns targeting past clients typically generate rebookings within the first 5 days — especially effective heading into spring and autumn."
    },
    {
        question: "Does it work with my existing software?",
        answer: "Yes. Our AI integrates with Jobber, LMN, Service Autopilot, Aspire, and most major landscaping business platforms. It also works with Google Calendar, Housecall Pro, and CRM tools. Nothing changes for your crews in the field."
    },
    {
        question: "What if a client wants a custom design consultation?",
        answer: "The AI handles routine enquiries, quote requests, scheduling, and follow-ups. Any client asking for a detailed design consultation or complex scope is transferred to you or your sales team instantly. You stay in control of every relationship."
    },
    {
        question: "How much should I spend on ads?",
        answer: "We recommend a minimum ad budget of $1,000/month for local landscaping campaigns. Most of our landscaping clients invest $1,500-$4,000/month and see 5-8x returns — a single hardscape or full-property project can pay for an entire quarter of ad spend."
    }
];
---

<Layout
    title="AI Marketing for Landscapers | Fill Your Pipeline Year-Round"
    description="Stop losing jobs to competitors who answer faster. SystemPros combines AI voice agents with Meta and Google advertising to keep your landscaping schedule packed — even in the slow months."
    showChatWidget={false}
>
    <ServiceSchema
        name="AI Marketing for Landscaping Companies"
        description="AI-powered marketing and advertising system for landscapers that captures every enquiry, books estimates 24/7, reactivates past clients, and drives new projects through Meta and Google ads."
        serviceType="Landscaping Marketing Automation"
    />
    <FAQSchema faqs={faqs} />

    <!-- SECTION 1: HERO — The Seasonal Trap -->
    <section class="relative min-h-screen flex items-center pt-20 pb-10 overflow-hidden bg-main">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-emerald-900/20 via-main to-main z-0"></div>
        <div class="absolute inset-0 bg-[url('/assets/grid.svg')] bg-center opacity-[0.03] pointer-events-none z-0"></div>

        <div class="container mx-auto px-4 z-10 max-w-5xl text-center">
            <div class="space-y-8 fade-up">
                <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/5 backdrop-blur-sm">
                    <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
                    <span class="text-emerald-300 text-xs font-bold tracking-wider uppercase">AI-Powered Landscaping Growth</span>
                </div>

                <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.1]">
                    Your Crews Are Booked. <br/>
                    <span class="bg-gradient-to-r from-emerald-400 via-green-400 to-emerald-400 bg-clip-text text-transparent">Your Phone Isn't.</span> <br/>
                    That's the Problem.
                </h1>

                <p class="text-xl text-secondary leading-relaxed max-w-2xl mx-auto">
                    Spring hits and every homeowner in town wants a quote. Your phone rings while your team is laying pavers. Nobody answers. That prospect calls the next landscaper on Google. <strong class="text-white">That's a $5,000-$50,000 project — gone before you even knew it existed.</strong>
                </p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/contact" class="btn-primary flex items-center justify-center gap-2 text-lg px-10 py-5 bg-gradient-to-r from-emerald-600 to-green-500 hover:from-emerald-500 hover:to-green-400 shadow-[0_0_40px_rgba(16,185,129,0.4)]">
                        Book Your Free Landscaping Growth Audit
                    </a>
                </div>

                <p class="text-sm text-secondary/60">No contracts. No pressure. Just a clear plan to fill your pipeline.</p>
            </div>
        </div>
    </section>

    <!-- SECTION 2: PAIN POINTS -->
    <section class="py-24 relative overflow-hidden bg-surface/30 border-y border-white/5">
        <div class="container mx-auto px-4 z-10 max-w-5xl">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold mb-6">Sound Familiar?</h2>
                <p class="text-xl text-secondary max-w-2xl mx-auto">
                    You started a landscaping business to build beautiful outdoor spaces. Not to sit around waiting for the phone to ring.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Pain 1 -->
                <div class="p-8 rounded-2xl border border-red-500/10 bg-red-500/5 hover:border-red-500/30 transition-all group">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-2xl shrink-0 group-hover:bg-red-500/20 transition-colors">
                            📱
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white mb-2">Missed Calls = Lost Projects</h3>
                            <p class="text-secondary text-sm leading-relaxed">
                                A homeowner sees your truck in their neighbour's yard. They call for a quote. No answer — you're running a chainsaw. They Google the next company. That's not a missed call — that's <strong class="text-red-400">a $10,000+ project</strong> you'll never even quote on.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Pain 2 -->
                <div class="p-8 rounded-2xl border border-red-500/10 bg-red-500/5 hover:border-red-500/30 transition-all group">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-2xl shrink-0 group-hover:bg-red-500/20 transition-colors">
                            ❄️
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white mb-2">The Winter Revenue Cliff</h3>
                            <p class="text-secondary text-sm leading-relaxed">
                                Spring and summer are slammed. Then winter arrives and revenue falls off a cliff. You've got crews to pay, equipment leases running, and <strong class="text-red-400">no system to generate off-season work</strong> — hardscaping, drainage projects, winter clean-ups, design consultations.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Pain 3 -->
                <div class="p-8 rounded-2xl border border-red-500/10 bg-red-500/5 hover:border-red-500/30 transition-all group">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-2xl shrink-0 group-hover:bg-red-500/20 transition-colors">
                            🐌
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white mb-2">Slow Quotes Kill Your Close Rate</h3>
                            <p class="text-secondary text-sm leading-relaxed">
                                A homeowner submits a quote request on your website Saturday evening. You see it Monday morning. By then they've booked someone else. <strong class="text-red-400">78% of projects go to the first responder</strong> — and right now, that's your competitor.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Pain 4 -->
                <div class="p-8 rounded-2xl border border-red-500/10 bg-red-500/5 hover:border-red-500/30 transition-all group">
                    <div class="flex items-start gap-4">
                        <div class="w-12 h-12 rounded-xl bg-red-500/10 flex items-center justify-center text-2xl shrink-0 group-hover:bg-red-500/20 transition-colors">
                            💤
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white mb-2">Past Clients Forget You Exist</h3>
                            <p class="text-secondary text-sm leading-relaxed">
                                You did an incredible patio build last year. The client raved about it. But when they need their garden redesigned, they Google "landscaper near me" instead of calling you. <strong class="text-red-400">Nobody is reminding them you exist.</strong> That repeat business is going to strangers.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 3: THE SOLUTION — The Landscaping Growth Engine -->
    <section class="py-32 relative">
        <div class="container mx-auto px-4 max-w-5xl">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-bold mb-4">
                    The <span class="bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent">Landscaping Growth Engine</span>
                </h2>
                <p class="text-secondary text-lg max-w-2xl mx-auto">
                    Three systems working together to fill your pipeline, eliminate dead seasons, and turn past clients into repeat revenue.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Pillar 1 -->
                <div class="glass-card hover:-translate-y-2 group">
                    <div class="w-14 h-14 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-6 text-2xl group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-300">
                        🤖
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">AI Receptionist</h3>
                    <p class="text-sm text-emerald-300 font-semibold mb-3">Every enquiry captured, every estimate booked</p>
                    <p class="text-secondary text-sm leading-relaxed mb-4">
                        Answers every call while your crew is on site. Books site visits, answers service questions, and handles scheduling. Sounds like your office manager — works around the clock for a fraction of the cost.
                    </p>
                    <ul class="space-y-2 text-sm text-secondary">
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            24/7 call answering — weekends included
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Books estimates directly into your calendar
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Integrates with Jobber, LMN & more
                        </li>
                    </ul>
                    <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden mt-6">
                        <div class="h-full bg-emerald-500 w-0 group-hover:w-full transition-all duration-700"></div>
                    </div>
                </div>

                <!-- Pillar 2 -->
                <div class="glass-card hover:-translate-y-2 group relative">
                    <div class="absolute -top-3 -right-3 bg-gradient-to-r from-emerald-500 to-green-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg shadow-emerald-500/50">CORE</div>
                    <div class="w-14 h-14 rounded-xl bg-green-500/10 flex items-center justify-center mb-6 text-2xl group-hover:bg-green-500 group-hover:text-white transition-colors duration-300">
                        🎯
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Meta & Google Ads</h3>
                    <p class="text-sm text-green-300 font-semibold mb-3">New projects on demand, year-round</p>
                    <p class="text-secondary text-sm leading-relaxed mb-4">
                        We build and manage hyper-local ad campaigns that put your work in front of homeowners ready to invest. Patios, retaining walls, garden designs, lawn care — we target the services with the highest margins and run campaigns that convert.
                    </p>
                    <ul class="space-y-2 text-sm text-secondary">
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Geo-targeted to your service radius
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Before & after project photos that sell
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Seasonal campaigns to kill the winter dip
                        </li>
                    </ul>
                    <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden mt-6">
                        <div class="h-full bg-green-500 w-0 group-hover:w-full transition-all duration-700 delay-100"></div>
                    </div>
                </div>

                <!-- Pillar 3 -->
                <div class="glass-card hover:-translate-y-2 group">
                    <div class="w-14 h-14 rounded-xl bg-emerald-500/10 flex items-center justify-center mb-6 text-2xl group-hover:bg-emerald-500 group-hover:text-white transition-colors duration-300">
                        🔄
                    </div>
                    <h3 class="text-xl font-bold text-white mb-2">Client Reactivation</h3>
                    <p class="text-sm text-emerald-300 font-semibold mb-3">Turn past clients into repeat revenue</p>
                    <p class="text-secondary text-sm leading-relaxed mb-4">
                        Our AI calls clients who haven't booked in 6+ months with a natural, personal message. "Hi Mark, it's been a while since we did your patio — we're booking autumn clean-ups and garden refreshes this month. Want me to schedule a visit?" Revenue from clients you've already won.
                    </p>
                    <ul class="space-y-2 text-sm text-secondary">
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Personalised AI outreach calls
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Seasonal upsell campaigns (spring prep, winter clean-up)
                        </li>
                        <li class="flex items-center gap-2">
                            <svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Fills slow months with repeat business
                        </li>
                    </ul>
                    <div class="h-1 w-full bg-white/5 rounded-full overflow-hidden mt-6">
                        <div class="h-full bg-emerald-500 w-0 group-hover:w-full transition-all duration-700 delay-200"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4: THE NUMBERS — What's Possible -->
    <section class="py-24 relative bg-surface/30 border-y border-white/5">
        <div class="absolute inset-0 opacity-20 pointer-events-none overflow-hidden">
            <div class="absolute inset-0 bg-[linear-gradient(45deg,transparent_25%,rgba(16,185,129,0.1)_50%,transparent_75%,transparent_100%)] bg-[length:40px_40px]"></div>
        </div>

        <div class="container mx-auto px-4 relative z-10 max-w-5xl">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-5xl font-bold mb-4">What a Full Pipeline <span class="bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent">Actually Looks Like</span></h2>
                <p class="text-secondary text-lg max-w-2xl mx-auto">
                    These are the shifts landscaping companies see when AI handles the phones and ads bring year-round work.
                </p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                <div class="text-center p-8 rounded-2xl border border-white/10 bg-surface/50 backdrop-blur-sm">
                    <div class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent mb-2">95%</div>
                    <div class="text-sm text-secondary">Calls Answered</div>
                    <div class="text-xs text-secondary/50 mt-1">even when crews are on site</div>
                </div>
                <div class="text-center p-8 rounded-2xl border border-white/10 bg-surface/50 backdrop-blur-sm">
                    <div class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent mb-2">5-8x</div>
                    <div class="text-sm text-secondary">Ad Spend ROI</div>
                    <div class="text-xs text-secondary/50 mt-1">one hardscape job covers months of ads</div>
                </div>
                <div class="text-center p-8 rounded-2xl border border-white/10 bg-surface/50 backdrop-blur-sm">
                    <div class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent mb-2">40%</div>
                    <div class="text-sm text-secondary">Winter Revenue Increase</div>
                    <div class="text-xs text-secondary/50 mt-1">seasonal campaigns + reactivation</div>
                </div>
                <div class="text-center p-8 rounded-2xl border border-white/10 bg-surface/50 backdrop-blur-sm">
                    <div class="text-4xl md:text-5xl font-extrabold bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent mb-2">35%</div>
                    <div class="text-sm text-secondary">Past Clients Rebooked</div>
                    <div class="text-xs text-secondary/50 mt-1">from AI reactivation in 30 days</div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 5: OLD WAY vs. SYSTEMPROS -->
    <section class="py-24">
        <div class="container mx-auto px-4 max-w-5xl">
            <h2 class="text-center text-3xl md:text-4xl font-bold mb-16">The old way vs. <span class="bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent">SystemPros</span></h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-0 md:gap-8">
                <!-- Old Way -->
                <div class="p-8 border-l-4 border-red-500/50 bg-surface/30 rounded-r-xl md:rounded-xl mb-8 md:mb-0">
                    <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                        <span class="text-red-500">&#10005;</span> What Most Landscapers Do
                    </h3>
                    <ul class="space-y-4 text-secondary">
                        <li class="flex items-start gap-3">
                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mt-2 shrink-0"></span>
                            Miss calls while on jobs — prospects call the next company
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mt-2 shrink-0"></span>
                            Return quote requests days late when the client has moved on
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mt-2 shrink-0"></span>
                            Rely on yard signs, word-of-mouth, and "the truck being seen"
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mt-2 shrink-0"></span>
                            Accept the winter revenue drop as "just how it is"
                        </li>
                        <li class="flex items-start gap-3">
                            <span class="w-1.5 h-1.5 bg-red-500 rounded-full mt-2 shrink-0"></span>
                            Never follow up with past clients for repeat work
                        </li>
                    </ul>
                </div>

                <!-- SystemPros -->
                <div class="p-8 border-l-4 border-emerald-500 bg-emerald-500/5 rounded-r-xl md:rounded-xl relative">
                    <div class="absolute -top-3 -right-3 bg-gradient-to-r from-emerald-500 to-green-500 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg shadow-emerald-500/50">YOUR UNFAIR ADVANTAGE</div>
                    <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-2">
                        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        The SystemPros Landscaping Engine
                    </h3>
                    <ul class="space-y-4 text-white">
                        <li class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-emerald-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            AI answers every call and books estimates instantly — 24/7
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-emerald-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Targeted Meta & Google ads driving local projects weekly
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-emerald-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Seasonal ad campaigns eliminate the winter revenue cliff
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-emerald-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            AI reactivation calls bring past clients back for new work
                        </li>
                        <li class="flex items-start gap-3">
                            <svg class="w-4 h-4 text-emerald-400 mt-1 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                            Full reporting dashboard — know your cost per lead to the dollar
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 6: HOW IT WORKS -->
    <section class="py-24 relative bg-surface/30 border-y border-white/5">
        <div class="container mx-auto px-4 max-w-4xl">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Live in <span class="bg-gradient-to-r from-emerald-400 to-green-400 bg-clip-text text-transparent">48 Hours</span></h2>
                <p class="text-secondary text-lg">Three steps. No tech skills required.</p>
            </div>

            <div class="space-y-8">
                <div class="flex items-start gap-6 group">
                    <div class="w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 font-bold text-lg shrink-0 group-hover:bg-emerald-500 group-hover:text-white transition-colors">1</div>
                    <div>
                        <h3 class="text-lg font-bold text-white mb-1">Free Landscaping Growth Audit</h3>
                        <p class="text-secondary text-sm leading-relaxed">We analyse your call answer rate, lead response time, seasonal revenue patterns, and client retention. You get a clear report showing exactly where projects are falling through the cracks — and how much they're worth.</p>
                    </div>
                </div>
                <div class="flex items-start gap-6 group">
                    <div class="w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center text-emerald-400 font-bold text-lg shrink-0 group-hover:bg-emerald-500 group-hover:text-white transition-colors">2</div>
                    <div>
                        <h3 class="text-lg font-bold text-white mb-1">We Build Your Growth Engine</h3>
                        <p class="text-secondary text-sm leading-relaxed">We deploy your AI receptionist, connect it to your scheduling platform, set up client reactivation campaigns, and launch your first ad campaigns — all within 48 hours. Your crews don't need to learn anything new.</p>
                    </div>
                </div>
                <div class="flex items-start gap-6 group">
