---
import { Image } from 'astro:assets';

interface Props {
  badge: string;
  title: string;
  subtitle: string;
  ctaText: string;
  ctaLink: string;
  secondaryCtaText?: string;
  secondaryCtaLink?: string;
  heroImage: ImageMetadata;
  heroImageAlt: string;
}

const { badge, title, subtitle, ctaText, ctaLink, secondaryCtaText, secondaryCtaLink, heroImage, heroImageAlt } = Astro.props;
---

<section class="min-h-screen relative flex items-center pt-32 pb-20">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-main to-main pointer-events-none"></div>

  <div class="container mx-auto px-4 grid lg:grid-cols-2 gap-12 items-center relative z-10">
    <!-- Text Left -->
    <div class="space-y-8 fade-up">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-blue-500/30 bg-blue-500/5 backdrop-blur-sm">
        <span class="text-accent text-xs font-bold tracking-wider uppercase">{badge}</span>
      </div>

      <!-- Title -->
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-tight" set:html={title} />

      <!-- Subtitle -->
      <p class="text-lg md:text-xl text-secondary max-w-xl leading-relaxed">{subtitle}</p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 pt-4">
        <a href={ctaLink} class="btn-primary text-center">{ctaText}</a>
        {secondaryCtaText && secondaryCtaLink && (
          <a href={secondaryCtaLink} class="px-8 py-4 rounded-full border border-white/20 hover:bg-white/5 hover:border-white/40 transition-all font-semibold text-white/90 text-center flex items-center justify-center gap-2">
            {secondaryCtaText}
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        )}
      </div>
    </div>

    <!-- Image Right -->
    <div class="relative h-[500px] w-full flex items-center justify-center fade-up" style="animation-delay: 0.2s;">
      <div class="absolute inset-0 bg-blue-500/10 blur-[100px] rounded-full"></div>
      <Image
        src={heroImage}
        alt={heroImageAlt}
        class="relative z-10 w-full object-contain drop-shadow-[0_0_50px_rgba(59,130,246,0.3)] hover:scale-105 transition-transform duration-700"
      />
    </div>
  </div>
</section>

<style>
  .fade-up {
    opacity: 0;
    animation: fade-up 0.8s ease-out forwards;
  }
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
