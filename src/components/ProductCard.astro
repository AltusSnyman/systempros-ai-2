---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  accentColor?: string;
}

const { title, description, href, icon, accentColor = 'accent' } = Astro.props;
---

<a href={href} class="glass-card group relative overflow-hidden flex flex-col hover:-translate-y-2 transition-all duration-300 hover:shadow-[0_20px_50px_rgba(59,130,246,0.15)]">
  <!-- Hover Glow -->
  <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

  <div class="relative z-10 flex flex-col h-full">
    <!-- Icon -->
    <div class="w-12 h-12 rounded-xl bg-accent/10 flex items-center justify-center mb-5 text-accent group-hover:bg-accent group-hover:text-white transition-colors duration-300">
      <Fragment set:html={icon} />
    </div>

    <!-- Title -->
    <h3 class="text-xl font-bold text-white mb-3 group-hover:text-accent transition-colors">{title}</h3>

    <!-- Description -->
    <p class="text-sm text-secondary leading-relaxed mb-6 flex-grow">{description}</p>

    <!-- Link -->
    <div class="flex items-center gap-2 text-sm font-semibold text-accent">
      Learn More
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </div>
  </div>
</a>
